---
interface Props {
  title?: string;
}

const { title = "Admin" } = Astro.props;

const menuItems = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Kelola Halaman", href: "/admin/KelolaHalaman" },
  { label: "Pendaftar", href: "/admin/pendaftar" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <title>{title} | Admin Panel</title>
  </head>
  <body>
    <div id="authLoading" class="auth-loading">
      <div class="loader-spinner"></div>
      <p>Memeriksa sesi login...</p>
    </div>

    <div id="adminWrapper" class="admin-wrapper" style="display:none;">
      <!-- SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-top">
          <div class="sidebar-brand">
            <span class="brand-text">Admin Panel</span>
          </div>

          <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <span class="toggle-icon">◀</span>
          </button>
        </div>

        <nav class="sidebar-nav">
          <ul>
            {menuItems.map((item) => (
              <li>
                <a 
                  href={item.href} 
                  class={currentPath === item.href ? "active" : ""}
                >
                  <span class="nav-label">{item.label}</span>
                  {currentPath === item.href && <span class="nav-indicator"></span>}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="sidebar-footer">
          <div class="user-profile">
            <div class="user-avatar" id="adminAvatar">
              <span id="adminInitial">A</span>
            </div>
            <div class="user-info">
              <span id="adminName" class="user-name">-</span>
              <small id="adminRole" class="user-role">-</small>
            </div>
          </div>
          <button id="logoutBtn" class="logout-btn">
            Logout
          </button>
        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <main class="admin-content">
        <div class="content-header">
          <h1>{title}</h1>
          <div class="header-actions">
            <span class="header-date" id="currentDate"></span>
          </div>
        </div>
        <div class="content-body">
          <slot />
        </div>
      </main>
    </div>

    <script type="module">
      import { authService } from "../services/authService";

      const authLoading = document.getElementById("authLoading");
      const adminWrapper = document.getElementById("adminWrapper");

      async function checkAuth() {
        adminWrapper.style.display = "none";
        authLoading.style.display = "flex";

        const admin = await authService.getAdmin();

        if (!admin) {
          window.location.replace("/login");
          return;
        }

        document.getElementById("adminName").textContent = admin.nama;
        document.getElementById("adminRole").textContent = admin.role;
        document.getElementById("adminInitial").textContent = admin.nama?.charAt(0) || "A";

        authLoading.style.display = "none";
        adminWrapper.style.display = "flex";
      }

      checkAuth();

      window.addEventListener("pageshow", (event) => {
        if (event.persisted) {
          checkAuth();
        }
      });

      document
        .getElementById("logoutBtn")
        ?.addEventListener("click", async (e) => {
          e.preventDefault();
          await authService.logout();
          window.location.replace("/login");
        });

      const sidebarToggle = document.getElementById("sidebarToggle");
      const sidebar = document.getElementById("sidebar");

      sidebarToggle?.addEventListener("click", () => {
        sidebar.classList.toggle("collapsed");
        const icon = sidebarToggle.querySelector(".toggle-icon");
        if (sidebar.classList.contains("collapsed")) {
          icon.textContent = "▶";
        } else {
          icon.textContent = "◀";
        }
      });

      const dateEl = document.getElementById("currentDate");
      if (dateEl) {
        const now = new Date();
        dateEl.textContent = now.toLocaleDateString("id-ID", {
          weekday: "long",
          day: "numeric",
          month: "long",
          year: "numeric",
        });
      }
    </script>

    <style>
      /* ----- RESET & BASE ----- */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: #f1f5f9;
        color: #0f172a;
      }

      /* ----- AUTH LOADING ----- */
      .auth-loading {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        color: #64748b;
        background: #f8fafc;
      }

      .loader-spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #e2e8f0;
        border-top-color: #2563eb;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      /* ----- ADMIN WRAPPER ----- */
      .admin-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f1f5f9;
      }

      /* ----- SIDEBAR ----- */
      .sidebar {
        width: 260px;
        background: #0f172a;
        color: #e2e8f0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 0;
        transition: width 0.3s ease, transform 0.3s ease;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        z-index: 100;
      }

      .sidebar::-webkit-scrollbar {
        width: 4px;
      }
      .sidebar::-webkit-scrollbar-track {
        background: #1e293b;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: #475569;
        border-radius: 4px;
      }

      .sidebar-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.25rem 0.75rem 1.25rem;
        border-bottom: 1px solid #1e293b;
      }

      .sidebar-brand {
        display: flex;
        align-items: center;
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
      }

      .sidebar-toggle {
        background: transparent;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        font-size: 0.8rem;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        transition: background 0.2s;
        display: none;
      }
      .sidebar-toggle:hover {
        background: #1e293b;
        color: #fff;
      }

      /* ----- SIDEBAR NAV ----- */
      .sidebar-nav {
        flex: 1;
        padding: 1rem 0.75rem;
      }

      .sidebar-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .sidebar-nav ul li a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.65rem 0.85rem;
        color: #94a3b8;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        position: relative;
      }

      .sidebar-nav ul li a:hover {
        background: #1e293b;
        color: #f1f5f9;
      }

      .sidebar-nav ul li a.active {
        background: #2563eb;
        color: #fff;
        box-shadow: 0 2px 8px rgba(37, 99, 235, 0.35);
      }

      .nav-label {
        flex: 1;
      }

      .nav-indicator {
        width: 4px;
        height: 20px;
        background: #fff;
        border-radius: 4px;
        flex-shrink: 0;
        margin-left: auto;
      }

      /* ----- SIDEBAR FOOTER ----- */
      .sidebar-footer {
        padding: 1rem 1.25rem 1.25rem;
        border-top: 1px solid #1e293b;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .user-profile {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        flex-shrink: 0;
      }

      .user-info {
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .user-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: #f1f5f9;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .user-role {
        font-size: 0.75rem;
        color: #94a3b8;
        text-transform: capitalize;
      }

      .logout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.5rem 0.85rem;
        background: transparent;
        border: 1px solid #334155;
        border-radius: 8px;
        color: #f87171;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        width: 100%;
      }
      .logout-btn:hover {
        background: #450a0a;
        border-color: #dc2626;
        color: #fca5a5;
      }

      /* ----- SIDEBAR COLLAPSED (Mobile) ----- */
      .sidebar.collapsed {
        width: 0;
        padding: 0;
        overflow: hidden;
        min-width: 0;
      }

      /* ----- ADMIN CONTENT ----- */
      .admin-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        padding: 0;
        background: #f1f5f9;
      }

      .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        flex-wrap: wrap;
        gap: 0.5rem;
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .content-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .header-date {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
      }

      .content-body {
        padding: 1.5rem 2rem 2rem;
        flex: 1;
      }

      /* ----- RESPONSIVE ----- */
      @media (max-width: 768px) {
        .sidebar {
          position: fixed;
          width: 280px;
          left: 0;
          top: 0;
          bottom: 0;
          transform: translateX(-100%);
          transition: transform 0.3s ease;
          height: 100vh;
          border-radius: 0;
        }

        .sidebar:not(.collapsed) {
          transform: translateX(0);
        }

        .sidebar-toggle {
          display: block;
        }

        .admin-content {
          width: 100%;
        }

        .content-header {
          padding: 1rem 1.25rem;
        }

        .content-header h1 {
          font-size: 1.2rem;
        }

        .content-body {
          padding: 1rem 1.25rem 1.5rem;
        }

        .sidebar.collapsed {
          transform: translateX(-100%);
        }
      }

      @media (min-width: 769px) {
        .sidebar-toggle {
          display: none;
        }
      }

      @media (max-width: 480px) {
        .content-header {
          flex-direction: column;
          align-items: stretch;
          gap: 0.5rem;
        }
        .header-actions {
          justify-content: flex-start;
        }
        .header-date {
          font-size: 0.75rem;
        }
      }
    </style>
  </body>
</html>