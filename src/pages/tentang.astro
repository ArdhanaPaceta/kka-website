---
// =============================================================
// pages/tentang.astro — Halaman Tentang (server-side data)
// =============================================================
import MainLayout from '../layouts/MainLayout.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import { createClient } from '@supabase/supabase-js';

// Ambil data keunggulan dari Supabase (server-side)
let keunggulanItems = [];
try {
  const supabase = createClient(
    import.meta.env.SUPABASE_URL,
    import.meta.env.SUPABASE_ANON_KEY
  );
  const { data, error } = await supabase
    .from('keunggulan')
    .select('id, judul, deskripsi, gambar_url, urutan')
    .order('urutan', { ascending: true });
  if (!error && data) {
    keunggulanItems = data;
  }
} catch (err) {
  console.error('Gagal fetch keunggulan:', err);
}

const milestones = [
  { year: '2019', desc: 'KKA pertama kali diselenggarakan dengan diikuti 20 sekolah.' },
  { year: '2021', desc: 'Perluasan kategori kompetisi mencakup jenjang SMK.' },
  { year: '2023', desc: 'Jumlah peserta menembus lebih dari 500 sekolah se-kabupaten.' },
  { year: '2026', desc: 'KKA hadir dengan sistem pendaftaran digital yang lebih mudah.' },
];
---

<MainLayout
  title="Tentang"
  description="Kenali visi, misi, dan sejarah penyelenggaraan Kompetisi Kompetensi Akademik (KKA)."
>
  <section class="page-hero">
    <div class="container mx-auto px-4 max-w-6xl">
      <h1 class="page-hero__title">Tentang Kompetisi Kompetensi Akademik</h1>
    </div>
  </section>

  <!-- Oper data ke komponen About (server-side rendered) -->
  <About items={keunggulanItems} />

  <!-- SECTION VISI & MISI -->
  <!-- Dihapus overflow-hidden dan ditambahkan bg-white agar solid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto max-w-6xl px-4 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      
      <!-- Kolom Kiri: Gambar & Badge (DIPERBAIKI) -->
      <!-- MENGGUNAKAN h-[400px] lg:h-[550px] AGAR TINGGI GAMBAR TERKUNCI DAN TIDAK BOCOR -->
      <div class="relative w-full h-[400px] lg:h-[520px] rounded-2xl shadow-lg reveal">
        <img 
          src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
          alt="Gedung Institusi" 
          class="w-full h-full object-cover rounded-2xl"
        />
        <div class="absolute bottom-5 left-5 lg:bottom-8 lg:left-8 bg-[#c93046] text-white p-5 lg:p-7 rounded-xl text-center shadow-2xl">
          <span class="block text-3xl lg:text-4xl font-extrabold leading-none mb-1 lg:mb-2">60+</span>
          <span class="block text-[10px] lg:text-xs font-bold tracking-widest uppercase leading-tight">TAHUN<br/>PENGALAMAN</span>
        </div>
      </div>

      <!-- Kolom Kanan: Teks & Kartu -->
      <div class="flex flex-col reveal reveal-delay-1">
        
        <!-- Header -->
        <div class="mb-8 lg:mb-10">
          <div class="flex items-center text-[#c93046] font-bold text-sm tracking-[0.15em] uppercase mb-4">
            <span class="w-10 h-0.5 bg-[#c93046] mr-3"></span>
            TENTANG KAMI
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold text-[#1a2b4c] leading-tight mb-5 lg:mb-6">
            Membentuk Masa Depan Melalui Pengetahuan & Penemuan
          </h2>
          <p class="text-slate-500 leading-relaxed text-sm lg:text-base">
            Kompetisi Kompetensi Akademik (KKA) berdedikasi untuk memberikan wadah terbaik bagi para pelajar. 
            Kami percaya bahwa iklim kompetisi yang sehat akan memicu semangat belajar dan melahirkan generasi muda yang siap menghadapi tantangan global.
          </p>
        </div>

        <!-- Kartu Visi Misi -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-xl p-6 lg:p-7 shadow-[0_4px_20px_rgba(0,0,0,0.06)] border-t-[3px] border-[#c93046] hover:-translate-y-1 transition-transform duration-300 flex flex-col">
            <span class="inline-flex items-center justify-center w-12 h-12 text-[#c93046] bg-[#c93046]/5 rounded-full mb-4 text-xl lg:text-2xl shrink-0">
              🎯
            </span>
            <h3 class="text-lg lg:text-xl font-bold text-[#1a2b4c] mb-2 lg:mb-3">Misi Kami</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Menyelenggarakan kompetisi yang adil dan mendidik, mendorong budaya belajar aktif, serta memperluas akses kompetisi bagi pelajar di seluruh kabupaten.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 lg:p-7 shadow-[0_4px_20px_rgba(0,0,0,0.06)] border-t-[3px] border-[#c93046] hover:-translate-y-1 transition-transform duration-300 flex flex-col">
            <span class="inline-flex items-center justify-center w-12 h-12 text-[#c93046] bg-[#c93046]/5 rounded-full mb-4 text-xl lg:text-2xl shrink-0">
              👁️
            </span>
            <h3 class="text-lg lg:text-xl font-bold text-[#1a2b4c] mb-2 lg:mb-3">Visi Kami</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Menjadi wadah kompetisi akademik terdepan yang melahirkan generasi pelajar unggul, berdaya saing, dan berintegritas tinggi.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Ditambahkan border-t transparan/bg agar benar-benar terpisah dari section atas -->
  <section class="py-16 lg:py-24 bg-slate-50 border-t border-slate-100">
    <div class="container mx-auto max-w-6xl px-4">
      <div class="mb-10 lg:mb-14 text-center reveal">
        <span class="text-[#c93046] font-bold text-xs lg:text-sm tracking-widest uppercase block mb-2 lg:mb-3">Perjalanan Kami</span>
        <h2 class="text-2xl lg:text-3xl font-bold text-[#1a2b4c]">Sejarah Singkat KKA</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {milestones.map((m, i) => (
          <div class:list={['bg-white p-6 lg:p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow reveal', `reveal-delay-${i + 1}`]}>
            <span class="block text-2xl lg:text-3xl font-bold text-[#1a2b4c] mb-2 lg:mb-3">{m.year}</span>
            <p class="text-slate-500 text-sm leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</MainLayout>