---
// =============================================================
// components/PopularPrograms.astro — Section Kompetisi Unggulan KKA
// =============================================================
---

<section class="popular-programs section">
  <div class="container">

    <!-- Header section -->
    <div class="section-header">
      <span class="badge">Kompetisi Unggulan</span>
      <h2>Kompetisi Kompetensi Akademik (KKA)</h2>
      <p>Ikuti ajang bergengsi untuk jenjang SD, SMP, SMA, dan SMK. Uji kemampuanmu dan raih prestasi!</p>
    </div>

    <!-- Grid cards -->
    <div class="programs-grid">

      <!-- Card 1: SD -->
      <div class="program-card">
        <div class="card-badge">SD</div>
        <h3 class="program-title">Kompetisi SD</h3>
        <p class="program-desc">
          Uji kemampuan dasar matematika, sains, dan bahasa Indonesia. Cocok untuk siswa kelas 4–6.
        </p>
        <div class="program-meta">
          <span class="meta-item">
            <i class="fas fa-users"></i> Kelas 4-6
          </span>
          <span class="meta-item">
            <i class="fas fa-trophy"></i> 3 Kategori
          </span>
        </div>
        <a href="/pendaftaran-kolektif" class="btn-primary">Daftar Sekarang →</a>
      </div>

      <!-- Card 2: SMP -->
      <div class="program-card">
        <div class="card-badge">SMP</div>
        <h3 class="program-title">Kompetisi SMP</h3>
        <p class="program-desc">
          Asah logika matematika, IPA terpadu, dan kemampuan literasi. Untuk siswa kelas 7–9.
        </p>
        <div class="program-meta">
          <span class="meta-item">
            <i class="fas fa-users"></i> Kelas 7-9
          </span>
          <span class="meta-item">
            <i class="fas fa-trophy"></i> 4 Kategori
          </span>
        </div>
        <a href="/pendaftaran-kolektif" class="btn-primary">Daftar Sekarang →</a>
      </div>

      <!-- Card 3: SMA (tetap highlight tapi semua card akan sama) -->
      <div class="program-card">
        <div class="card-badge">SMA</div>
        <h3 class="program-title">Kompetisi SMA</h3>
        <p class="program-desc">
          Tantangan tingkat lanjut dalam matematika, fisika, kimia, biologi, dan ekonomi. Untuk siswa kelas 10–12.
        </p>
        <div class="program-stats">
          <span><strong>5</strong> Bidang</span>
          <span><strong>+500</strong> Peserta</span>
        </div>
        <a href="/pendaftaran-kolektif" class="btn-primary">Daftar Sekarang →</a>
      </div>

      <!-- Card 4: SMK -->
      <div class="program-card">
        <div class="card-badge">SMK</div>
        <h3 class="program-title">Kompetisi SMK</h3>
        <p class="program-desc">
          Kompetisi vokasi yang menguji keterampilan praktis dan teori di bidang teknik, bisnis, dan TI.
        </p>
        <div class="program-meta">
          <span class="meta-item">
            <i class="fas fa-users"></i> Semua Jurusan
          </span>
          <span class="meta-item">
            <i class="fas fa-trophy"></i> 6 Bidang Lomba
          </span>
        </div>
        <a href="/pendaftaran-kolektif" class="btn-primary">Daftar Sekarang →</a>
      </div>

    </div>
  </div>
</section>

<style>
  /* ============================================
     SECTION WRAPPER
     ============================================ */
  .popular-programs {
    padding: 80px 0 100px;
    background: #f8faff;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ============================================
     SECTION HEADER
     ============================================ */
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .section-header .badge {
    display: inline-block;
    background: #ffc107;
    color: #1a1a2e;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 6px 18px;
    border-radius: 30px;
    margin-bottom: 15px;
  }

  .section-header h2 {
    font-size: 38px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 12px;
  }

  .section-header p {
    font-size: 18px;
    color: #555;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ============================================
     GRID CARDS
     ============================================ */
  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 30px;
  }

  /* ============================================
     INDIVIDUAL CARD — SEMUA HITAM
     ============================================ */
  .program-card {
    background: linear-gradient(145deg, #1a1a2e, #2a2a4e);
    border-radius: 16px;
    padding: 30px 25px 35px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: #fff; /* teks putih default */
  }

  .program-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  /* Card badge */
  .program-card .card-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #fff;
    color: #1a1a2e;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 14px;
    border-radius: 30px;
  }

  .program-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .program-desc {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    margin: 0 0 20px 0;
    flex: 1;
  }

  /* Meta info */
  .program-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 20px;
    width: 100%;
  }

  .meta-item {
    font-size: 14px;
    color: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .meta-item i {
    color: #ffc107;
    font-size: 16px;
    width: 18px;
  }

  /* Stats khusus untuk card SMA */
  .program-stats {
    display: flex;
    gap: 30px;
    margin-bottom: 20px;
    width: 100%;
  }

  .program-stats span {
    font-size: 15px;
    color: rgba(255,255,255,0.9);
  }

  .program-stats strong {
    font-size: 20px;
    color: #fff;
    display: block;
  }

  /* ============================================
     BUTTONS
     ============================================ */
  .btn-outline,
  .btn-primary {
    display: inline-block;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 30px;
    transition: all 0.3s ease;
    margin-top: auto;
    align-self: flex-start;
  }

  .btn-outline {
    color: #fff;
    background: transparent;
    border: 2px solid rgba(255,255,255,0.5);
  }

  .btn-outline:hover {
    background: #fff;
    color: #1a1a2e;
    border-color: #fff;
  }

  .btn-primary {
    background: #ffc107;
    color: #1a1a2e;
    border: 2px solid #ffc107;
  }

  .btn-primary:hover {
    background: #fff;
    border-color: #fff;
    color: #1a1a2e;
  }

  /* Hapus kelas highlight karena semua sudah hitam */
  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .popular-programs {
      padding: 60px 0 70px;
    }

    .section-header h2 {
      font-size: 30px;
    }

    .section-header p {
      font-size: 16px;
    }

    .programs-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .program-card {
      padding: 25px 20px 30px;
    }

    .program-title {
      font-size: 20px;
    }
  }

  @media (max-width: 480px) {
    .program-meta {
      flex-direction: column;
      gap: 8px;
    }

    .program-stats {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>