---
// =============================================================
// components/Contact.astro
// Section "Kontak" — info kontak di-fetch CLIENT-SIDE supaya
// selalu update tanpa perlu rebuild.
// =============================================================
---

<section class="contact section" id="kontak">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Kontak</span>
      <h2 class="section-title">Hubungi Kami</h2>
      <p class="section-subtitle mx-auto">
        Ada pertanyaan seputar kompetisi? Kirimkan pesan Anda atau hubungi kami melalui kontak
        di bawah ini.
      </p>
    </div>

    <div class="contact__grid">
      <form class="contact__form reveal" id="contactForm" novalidate>
        <div class="contact__field">
          <label for="nama">Nama</label>
          <input type="text" id="nama" name="nama" placeholder="Masukkan nama lengkap Anda" required />
        </div>

        <div class="contact__field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="nama@email.com" required />
        </div>

        <div class="contact__field">
          <label for="pesan">Pesan</label>
          <textarea id="pesan" name="pesan" rows="5" placeholder="Tulis pesan Anda di sini..." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary contact__submit" id="contactSubmitBtn">
          <span class="contact__submit-text">Kirim Pesan</span>
          <span class="contact__submit-loading" style="display:none;">Mengirim...</span>
        </button>

        <p class="contact__status" id="contactStatus" role="status"></p>
      </form>

      <div class="contact__info reveal reveal-delay-2">
        <div id="contactInfoLoading" class="contact__info-loading">Memuat info kontak...</div>

        <!-- Diisi via JS setelah fetch selesai -->
        <div id="contactInfoItems" style="display:none;">
          <div class="contact__info-item">
            <span class="contact__info-icon">📍</span>
            <div>
              <h4>Alamat</h4>
              <p id="infoAlamat">-</p>
            </div>
          </div>

          <div class="contact__info-item">
            <span class="contact__info-icon">✉️</span>
            <div>
              <h4>Email</h4>
              <p id="infoEmail">-</p>
            </div>
          </div>

          <div class="contact__info-item">
            <span class="contact__info-icon">💬</span>
            <div>
              <h4>WhatsApp</h4>
              <p id="infoWhatsapp">-</p>
            </div>
          </div>

          <div class="contact__map">
            <iframe
              id="infoMapFrame"
              title="Lokasi Kompetisi Kompetensi Akademik"
              src=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  import { supabase } from '../lib/supabase';

  // =============================================================
  // 1. Muat info kontak (alamat, email, whatsapp, peta) — client-side
  // =============================================================
  const infoLoadingEl = document.getElementById('contactInfoLoading');
  const infoItemsEl = document.getElementById('contactInfoItems');

  async function loadContactInfo() {
    try {
      const { data: contact, error } = await supabase.from('contact_info').select('*').single();
      if (error) throw error;

      document.getElementById('infoAlamat').textContent = contact?.alamat ?? '-';
      document.getElementById('infoEmail').textContent = contact?.email ?? '-';
      document.getElementById('infoWhatsapp').textContent = contact?.whatsapp ?? '-';
      document.getElementById('infoMapFrame').src = contact?.map_embed_url ?? '';

      infoLoadingEl.style.display = 'none';
      infoItemsEl.style.display = 'block';
    } catch (err) {
      infoLoadingEl.textContent = 'Gagal memuat info kontak.';
      console.error('Gagal memuat info kontak:', err.message || err);
    }
  }

  loadContactInfo();

  // =============================================================
  // 2. Submit form pesan ke Supabase
  //    (Hanya SATU listener submit — sebelumnya ada 2 script yang
  //    sama-sama attach listener, menyebabkan submit ganda)
  // =============================================================
  const form = document.getElementById('contactForm');
  const status = document.getElementById('contactStatus');
  const submitBtn = document.getElementById('contactSubmitBtn');
  const submitText = submitBtn.querySelector('.contact__submit-text');
  const submitLoading = submitBtn.querySelector('.contact__submit-loading');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nama = document.getElementById('nama').value.trim();
    const email = document.getElementById('email').value.trim();
    const pesan = document.getElementById('pesan').value.trim();

    if (!nama || !email || !pesan) {
      status.textContent = 'Mohon lengkapi seluruh kolom terlebih dahulu.';
      status.style.color = '#dc2626';
      return;
    }

    submitBtn.disabled = true;
    submitText.style.display = 'none';
    submitLoading.style.display = 'inline';
    status.textContent = '';

    try {
      const { error } = await supabase.from('contact_messages').insert({ nama, email, pesan });
      if (error) throw error;

      status.textContent = 'Pesan berhasil dikirim, terima kasih!';
      status.style.color = '#16a34a';
      form.reset();
    } catch (err) {
      status.textContent = 'Gagal mengirim pesan: ' + err.message;
      status.style.color = '#dc2626';
    } finally {
      submitBtn.disabled = false;
      submitText.style.display = 'inline';
      submitLoading.style.display = 'none';
    }
  });
</script>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: start;
  }

  .contact__form {
    background: var(--color-light);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact__field label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .contact__field input,
  .contact__field textarea {
    padding: 13px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    color: var(--color-dark);
    resize: vertical;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }

  .contact__submit {
    align-self: flex-start;
  }

  .contact__status {
    font-size: 0.88rem;
    color: var(--color-secondary);
    min-height: 1.2em;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact__info-loading {
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  .contact__info-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .contact__info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    background: rgba(30, 58, 138, 0.08);
    border-radius: var(--radius-sm);
    font-size: 1.1rem;
  }

  .contact__info-item h4 {
    font-size: 0.98rem;
    margin-bottom: 4px;
  }

  .contact__info-item p {
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  .contact__map {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    aspect-ratio: 16 / 11;
    margin-top: 24px;
  }

  .contact__map iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>