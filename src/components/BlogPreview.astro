---
// =============================================================
// components/BlogPreview.astro
// Section "Blog Preview" — 3 artikel terbaru dari Supabase
// =============================================================
import { supabase } from '../lib/supabase';

const { data: articles, error } = await supabase
  .from('blog_artikel')
  .select('id, judul, tanggal, ringkasan, gambar')
  .order('tanggal', { ascending: false })
  .limit(3);

if (error) {
  console.error('Gagal memuat artikel blog:', error.message);
}

const posts = articles ?? [];

function formatTanggal(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<section class="blog section" id="blog">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Blog & Berita</span>
      <h2 class="section-title">Kabar Terbaru Seputar KKA</h2>
      <p class="section-subtitle mx-auto">
        Ikuti artikel, tips, dan berita terbaru seputar Kompetisi Kompetensi Akademik.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="blog__empty">Belum ada artikel yang dipublikasikan.</p>
    ) : (
      <div class="blog__grid">
        {posts.map((post, i) => (
          <article class:list={['blog__card', 'card', 'reveal', `reveal-delay-${i + 1}`]}>
            <div class="blog__image">
              {post.gambar ? (
                <img src={post.gambar} alt={post.judul} loading="lazy" />
              ) : (
                <div class="blog__image-empty" />
              )}
            </div>
            <div class="blog__body">
              <span class="blog__date">{formatTanggal(post.tanggal)}</span>
              <h3 class="blog__title">{post.judul}</h3>
              <p class="blog__excerpt">{post.ringkasan}</p>
              <a href={`/blog/${post.id}`} class="blog__link">Baca Selengkapnya →</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .blog__card {
    overflow: hidden;
  }

  .blog__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .blog__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog__image-empty {
    width: 100%;
    height: 100%;
    background: #f1f5f9;
  }

  .blog__card:hover .blog__image img {
    transform: scale(1.08);
  }

  .blog__body {
    padding: 26px;
  }

  .blog__date {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog__title {
    font-size: 1.1rem;
    margin-block: 10px 12px;
  }

  .blog__excerpt {
    color: var(--color-gray);
    font-size: 0.9rem;
    margin-bottom: 18px;
  }

  .blog__link {
    font-weight: 600;
    color: var(--color-secondary);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .blog__link:hover {
    color: var(--color-primary);
  }

  .blog__empty {
    text-align: center;
    color: var(--color-gray);
    padding: 40px 0;
  }

  @media (max-width: 900px) {
    .blog__grid {
      grid-template-columns: 1fr;
    }
  }
</style>