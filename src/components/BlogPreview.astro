---
// =============================================================
// components/BlogPreview.astro
// Section "Blog" — daftar artikel dari Supabase (client-side fetch)
//
// Cara pakai:
//   <BlogPreview />           -> tampilkan SEMUA artikel
//   <BlogPreview limit={3} /> -> tampilkan cuma 3 artikel terbaru (mis. di homepage)
// =============================================================

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
---

<section class="blog section" id="blog" data-limit={limit ?? ''}>
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Blog & Berita</span>
      <h2 class="section-title">Kabar Terbaru Seputar KKA</h2>
      <p class="section-subtitle mx-auto">
        Ikuti artikel, tips, dan berita terbaru seputar Kompetisi Kompetensi Akademik.
      </p>
    </div>

    <!-- Loading state -->
    <p class="blog__empty" id="blogLoading">Memuat artikel...</p>

    <!-- Empty state -->
    <p class="blog__empty" id="blogEmpty" style="display:none;">Belum ada artikel yang dipublikasikan.</p>

    <!-- Grid, diisi via JS -->
    <div class="blog__grid" id="blogGrid" style="display:none;"></div>
  </div>
</section>

<script type="module">
  import { supabase } from '../lib/supabase';

  const sectionEl = document.getElementById('blog');
  const loadingEl = document.getElementById('blogLoading');
  const emptyEl = document.getElementById('blogEmpty');
  const gridEl = document.getElementById('blogGrid');

  // Ambil limit dari data-attribute. Kalau kosong -> tampilkan semua artikel.
  const limitAttr = sectionEl.dataset.limit;
  const limit = limitAttr ? parseInt(limitAttr, 10) : null;

  function formatTanggal(dateStr) {
    return new Date(dateStr).toLocaleDateString('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }

  function escapeHtml(str) {
    return String(str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function renderGrid(posts) {
    // CATATAN: class "reveal"/"reveal-delay-X" SENGAJA tidak dipakai di sini,
    // karena elemen ini muncul async setelah fetch selesai, sehingga
    // IntersectionObserver scroll-animation global tidak pernah "melihat"
    // elemen ini -> opacity tetap 0 selamanya, kelihatan seperti kosong
    // padahal datanya ada.
    gridEl.innerHTML = posts.map((post) => `
      <article class="blog__card card">
        <div class="blog__image">
          ${post.gambar
            ? `<img src="${post.gambar}" alt="${escapeHtml(post.judul)}" loading="lazy" />`
            : `<div class="blog__image-empty"></div>`}
        </div>
        <div class="blog__body">
          <span class="blog__date">${formatTanggal(post.tanggal)}</span>
          <h3 class="blog__title">${escapeHtml(post.judul)}</h3>
          <p class="blog__excerpt">${escapeHtml(post.ringkasan)}</p>
          <a href="/blog/${post.id}" class="blog__link">Baca Selengkapnya →</a>
        </div>
      </article>
    `).join('');
  }

  async function loadArticles() {
    loadingEl.style.display = 'block';
    emptyEl.style.display = 'none';
    gridEl.style.display = 'none';

    try {
      let query = supabase
        .from('blog_artikel')
        .select('id, judul, tanggal, ringkasan, gambar')
        .order('tanggal', { ascending: false });

      // Cuma dibatasi kalau prop limit diisi. Kalau tidak, ambil semua.
      if (limit) {
        query = query.limit(limit);
      }

      const { data: articles, error } = await query;

      if (error) throw error;

      const posts = articles ?? [];
      loadingEl.style.display = 'none';

      if (posts.length === 0) {
        emptyEl.style.display = 'block';
        return;
      }

      gridEl.style.display = 'grid';
      renderGrid(posts);
    } catch (err) {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'block';
      emptyEl.textContent = 'Gagal memuat artikel.';
      console.error('Gagal memuat artikel blog:', err.message || err);
    }
  }

  loadArticles();
</script>

<style>
  /* PENTING: elemen di dalam #blogGrid dibuat lewat innerHTML, jadi TIDAK
     mendapat atribut scoping otomatis dari Astro. Semua selector untuk
     elemen tersebut WAJIB dibungkus :global(...) supaya CSS ini benar-benar
     berlaku, kalau tidak kartu blog akan tampil polos tanpa styling. */

  .blog__empty {
    text-align: center;
    color: var(--color-gray);
    padding: 40px 0;
  }

  :global(.blog__grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  :global(.blog__card) {
    overflow: hidden;
  }

  :global(.blog__image) {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  :global(.blog__image img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  :global(.blog__image-empty) {
    width: 100%;
    height: 100%;
    background: #f1f5f9;
  }

  :global(.blog__card:hover .blog__image img) {
    transform: scale(1.08);
  }

  :global(.blog__body) {
    padding: 26px;
  }

  :global(.blog__date) {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  :global(.blog__title) {
    font-size: 1.1rem;
    margin-block: 10px 12px;
  }

  :global(.blog__excerpt) {
    color: var(--color-gray);
    font-size: 0.9rem;
    margin-bottom: 18px;
  }

  :global(.blog__link) {
    font-weight: 600;
    color: var(--color-secondary);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  :global(.blog__link:hover) {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    :global(.blog__grid) {
      grid-template-columns: 1fr;
    }
  }
</style>