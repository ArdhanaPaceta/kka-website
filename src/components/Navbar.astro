---
// =============================================================
// components/Navbar.astro
// Sticky navbar + dropdown "Informasi" (tanpa Cek Pendaftaran)
// =============================================================
import { supabase } from "../lib/supabase";

const currentPath = Astro.url.pathname;
let menuItems = [];

const { data, error } = await supabase
  .from('navbar_menus')
  .select('label, href, urutan')
  .order('urutan', { ascending: true });

if (data && !error && data.length > 0) {
  menuItems = data;
} else {
  menuItems = [
    { label: 'Beranda', href: '/' },
    { label: 'Informasi', href: '/informasi' },
    { label: 'Tentang', href: '/tentang' },
  ];
}

const informasiSubmenu = [
  { label: 'Pendaftaran Mandiri', href: '/pendaftaran-mandiri' },
  { label: 'Pendaftaran Kolektif', href: '/pendaftaran-kolektif' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__brand" style="text-decoration: none;">
      <span class="navbar__brand-text">KKA</span>
    </a>

    <nav class="navbar__menu" id="navbarMenu">
      <ul>
        {menuItems.map((item) => (
          item.label === 'Informasi' ? (
            <li class="navbar__item navbar__item--dropdown">
              <div class="navbar__dropdown-wrapper">
                <a href={item.href} class:list={['navbar__link', { 'is-active': isActive(item.href) }]}>
                  {item.label}
                </a>
                <button
                  type="button"
                  class="navbar__dropdown-toggle"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-label="Buka submenu Informasi"
                >
                  <svg class="navbar__chevron" width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>

              <div class="navbar__dropdown">
                {informasiSubmenu.map((sub) => (
                  <a href={sub.href} class="navbar__dropdown-link">
                    {sub.label}
                  </a>
                ))}
              </div>
            </li>
          ) : (
            <li>
              <a href={item.href} class:list={['navbar__link', { 'is-active': isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="navbar__actions">
      <button class="navbar__toggle" id="navbarToggle" aria-label="Buka menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navbarToggle');
  const menu = document.getElementById('navbarMenu');

  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 40) {
      navbar.classList.add('is-scrolled');
    } else {
      navbar.classList.remove('is-scrolled');
    }
  }

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
    navbar?.classList.toggle('is-scrolled', Boolean(isOpen) || window.scrollY > 40);
  });

  // Dropdown "Informasi"
  const dropdownItem = document.querySelector('.navbar__item--dropdown');
  const dropdownToggle = dropdownItem?.querySelector('.navbar__dropdown-toggle');

  dropdownToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const isOpen = dropdownItem?.classList.toggle('is-open');
    dropdownToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  // Tutup dropdown saat klik di luar
  document.addEventListener('click', (e) => {
    if (dropdownItem && !dropdownItem.contains(e.target)) {
      dropdownItem.classList.remove('is-open');
      dropdownToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Tutup menu mobile & dropdown saat link submenu diklik
  menu?.querySelectorAll('.navbar__dropdown-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      dropdownItem?.classList.remove('is-open');
      dropdownToggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  /* ===== DROPDOWN WRAPPER (Desktop) ===== */
  .navbar__item--dropdown {
    position: relative;
  }

  .navbar__dropdown-wrapper {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .navbar__dropdown-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 0;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .navbar__dropdown-toggle:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .navbar.is-scrolled .navbar__dropdown-toggle:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  .navbar__chevron {
    transition: transform 0.25s ease;
  }

  .navbar__item--dropdown.is-open .navbar__chevron {
    transform: rotate(180deg);
  }

  /* ===== DROPDOWN MENU (Desktop) ===== */
  .navbar__dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 220px;
    background: var(--color-white);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
  }

  .navbar__item--dropdown.is-open .navbar__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .navbar__dropdown-link {
    display: block;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-dark);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .navbar__dropdown-link:hover {
    background: var(--color-bg, #f1f5f9);
    color: var(--color-primary, #2563eb);
  }

  /* ===== NAVBAR UTAMA ===== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: transparent;
    transition: background var(--transition-base, 0.3s), box-shadow var(--transition-base, 0.3s), padding var(--transition-base, 0.3s);
    padding-block: 22px;
  }

  .navbar.is-scrolled {
    background: var(--color-white);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    padding-block: 14px;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
  }

  .navbar__brand-text {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-white);
    transition: color var(--transition-base, 0.3s);
    letter-spacing: 0.02em;
  }

  .navbar.is-scrolled .navbar__brand-text {
    color: var(--color-dark);
  }

  .navbar__menu ul {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
    padding-block: 6px;
    transition: color 0.2s;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0%;
    height: 2px;
    background: var(--color-accent, #3b82f6);
    border-radius: 2px;
    transition: width 0.25s ease;
  }

  .navbar__link:hover,
  .navbar__link.is-active {
    color: var(--color-white);
  }

  .navbar__link:hover::after,
  .navbar__link.is-active::after {
    width: 100%;
  }

  .navbar.is-scrolled .navbar__link {
    color: var(--color-dark);
  }

  .navbar.is-scrolled .navbar__link:hover,
  .navbar.is-scrolled .navbar__link.is-active {
    color: var(--color-primary, #2563eb);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .navbar__toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-white);
    transition: background 0.2s;
  }

  .navbar.is-scrolled .navbar__toggle span {
    background: var(--color-dark);
  }

  /* ===== RESPONSIVE (Mobile) ===== */
  @media (max-width: 900px) {
    .navbar__toggle {
      display: flex;
    }

    .navbar__menu {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: min(320px, 80vw);
      background: var(--color-white);
      box-shadow: var(--shadow-lg);
      padding: 100px 32px 32px;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .navbar__menu.is-open {
      transform: translateX(0);
    }

    .navbar__menu ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      width: 100%;
    }

    .navbar__link {
      color: var(--color-dark) !important;
      font-size: 1.05rem;
      width: 100%;
      justify-content: space-between;
    }

    .navbar__link::after {
      bottom: -4px;
    }

    .navbar__item--dropdown {
      width: 100%;
    }

    .navbar__dropdown-wrapper {
      width: 100%;
      position: relative;
    }

    .navbar__dropdown-toggle {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    .navbar__dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      box-shadow: none;
      background: var(--color-bg, #f8fafc);
      margin-top: 4px;
      padding: 4px;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      width: 100%;
      transform: none;
    }

    .navbar__item--dropdown.is-open .navbar__dropdown {
      max-height: 200px;
    }
  }
</style>