---
// =============================================================
// components/Navbar.astro
// Sticky navbar + dropdown "Informasi" + tombol "Cek Status"
// =============================================================
import { supabase } from "../lib/supabase";

const currentPath = Astro.url.pathname;
let menuItems = [];

const { data, error } = await supabase
  .from('navbar_menus')
  .select('label, href, urutan')
  .order('urutan', { ascending: true });

if (data && !error && data.length > 0) {
  menuItems = data;
} else {
  menuItems = [
    { label: 'Beranda', href: '/' },
    { label: 'Informasi', href: '/informasi' },
    { label: 'Tentang', href: '/tentang' },
  ];
}

const informasiSubmenu = [
  { label: 'Pendaftaran Mandiri', href: '/pendaftaran-mandiri' },
  { label: 'Pendaftaran Kolektif', href: '/pendaftaran-kolektif' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__brand" style="text-decoration: none;">
      <span class="navbar__brand-text">KKA</span>
    </a>

    <nav class="navbar__menu" id="navbarMenu">
      <ul>
        {menuItems.map((item) => (
          item.label === 'Informasi' ? (
            <li class="navbar__item navbar__item--dropdown">
              <div class="navbar__dropdown-wrapper">
                <a href={item.href} class:list={['navbar__link', { 'is-active': isActive(item.href) }]}>
                  {item.label}
                </a>
                <button
                  type="button"
                  class="navbar__dropdown-toggle"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-label="Buka submenu Informasi"
                >
                  <svg class="navbar__chevron" width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>

              <div class="navbar__dropdown">
                {informasiSubmenu.map((sub) => (
                  <a href={sub.href} class="navbar__dropdown-link">
                    {sub.label}
                  </a>
                ))}
              </div>
            </li>
          ) : (
            <li>
              <a href={item.href} class:list={['navbar__link', { 'is-active': isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="navbar__actions">
      <button type="button" class="navbar__cek-btn" id="cekStatusBtn">
        🔍 Cek Status
      </button>
      <button class="navbar__toggle" id="navbarToggle" aria-label="Buka menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- ===================== MODAL CEK STATUS ===================== -->
<div class="cek-modal" id="cekModal">
  <div class="cek-modal__backdrop" id="cekModalBackdrop"></div>

  <div class="cek-modal__card">
    <button type="button" class="cek-modal__close" id="cekModalClose" aria-label="Tutup">✕</button>

    <h2 class="cek-modal__title">Cek Status Pendaftaran</h2>
    <p class="cek-modal__subtitle">Masukkan kode pendaftaran Anda (contoh: KKA-2026-0021)</p>

    <div class="cek-search">
      <input
        type="text"
        id="cekKodeInput"
        class="cek-search__input"
        placeholder="KKA-2026-0021"
        autocomplete="off"
      />
      <button type="button" id="cekSearchBtn" class="cek-search__btn">
        <span class="cek-search__btn-text">Cari</span>
        <span class="cek-search__btn-loading" style="display:none;">Mencari...</span>
      </button>
    </div>

    <p id="cekError" class="cek-error" style="display:none;"></p>

    <div id="cekResult" class="cek-result" style="display:none;">
      <div class="cek-result__row">
        <span class="cek-result__label">Nama Siswa</span>
        <span class="cek-result__value" id="cekResultNama">-</span>
      </div>
      <div class="cek-result__row">
        <span class="cek-result__label">Kode Pendaftaran</span>
        <span class="cek-result__value" id="cekResultKode">-</span>
      </div>
      <div class="cek-result__row">
        <span class="cek-result__label">Status</span>
        <span class="cek-result__value">
          <span id="cekResultStatus" class="cek-status-badge">-</span>
        </span>
      </div>
    </div>
  </div>
</div>

<script type="module">
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ========== NAVBAR ==========
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navbarToggle');
  const menu = document.getElementById('navbarMenu');

  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 40) {
      navbar.classList.add('is-scrolled');
    } else {
      navbar.classList.remove('is-scrolled');
    }
  }

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
    navbar?.classList.toggle('is-scrolled', Boolean(isOpen) || window.scrollY > 40);
  });

  // Dropdown "Informasi"
  const dropdownItem = document.querySelector('.navbar__item--dropdown');
  const dropdownToggle = dropdownItem?.querySelector('.navbar__dropdown-toggle');

  dropdownToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const isOpen = dropdownItem?.classList.toggle('is-open');
    dropdownToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  document.addEventListener('click', (e) => {
    if (dropdownItem && !dropdownItem.contains(e.target)) {
      dropdownItem.classList.remove('is-open');
      dropdownToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  menu?.querySelectorAll('.navbar__dropdown-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      dropdownItem?.classList.remove('is-open');
      dropdownToggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // ========== MODAL CEK STATUS ==========
  const cekBtn = document.getElementById('cekStatusBtn');
  const modal = document.getElementById('cekModal');
  const backdrop = document.getElementById('cekModalBackdrop');
  const closeBtn = document.getElementById('cekModalClose');

  const kodeInput = document.getElementById('cekKodeInput');
  const searchBtn = document.getElementById('cekSearchBtn');
  const searchBtnText = searchBtn?.querySelector('.cek-search__btn-text');
  const searchBtnLoading = searchBtn?.querySelector('.cek-search__btn-loading');

  const cekError = document.getElementById('cekError');
  const cekResult = document.getElementById('cekResult');
  const resultNama = document.getElementById('cekResultNama');
  const resultKode = document.getElementById('cekResultKode');
  const resultStatus = document.getElementById('cekResultStatus');

  function openModal() {
    modal?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    setTimeout(() => kodeInput?.focus(), 100);
  }

  function closeModal() {
    modal?.classList.remove('is-open');
    document.body.style.overflow = '';
    resetModal();
  }

  function resetModal() {
    if (kodeInput) kodeInput.value = '';
    if (cekError) cekError.style.display = 'none';
    if (cekResult) cekResult.style.display = 'none';
  }

  cekBtn?.addEventListener('click', openModal);
  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal();
  });

  function statusClass(status) {
    const map = {
      'Menunggu Pembayaran': 'cek-status-badge--pending',
      'Menunggu Verifikasi': 'cek-status-badge--review',
      'Terverifikasi': 'cek-status-badge--success',
      'Ditolak': 'cek-status-badge--danger',
    };
    return map[status] || 'cek-status-badge--pending';
  }

  async function cariPendaftaran() {
    if (!kodeInput || !cekError || !cekResult || !searchBtn) return;
    const kode = kodeInput.value.trim();
    cekError.style.display = 'none';
    cekResult.style.display = 'none';

    if (!kode) {
      cekError.textContent = 'Masukkan kode pendaftaran terlebih dahulu.';
      cekError.style.display = 'block';
      return;
    }

    if (searchBtnText) searchBtnText.style.display = 'none';
    if (searchBtnLoading) searchBtnLoading.style.display = 'inline';
    searchBtn.disabled = true;

    try {
      const { data, error } = await supabase
        .from('pendaftar')
        .select('id, nama_siswa, kode_pendaftaran, status')
        .ilike('kode_pendaftaran', kode)
        .maybeSingle();

      if (error) throw new Error(error.message);

      if (!data) {
        cekError.textContent = 'Kode pendaftaran tidak ditemukan. Periksa kembali penulisannya.';
        cekError.style.display = 'block';
        return;
      }

      if (resultNama) resultNama.textContent = data.nama_siswa || '-';
      if (resultKode) resultKode.textContent = data.kode_pendaftaran || '-';
      const statusText = data.status || 'Menunggu Pembayaran';
      if (resultStatus) {
        resultStatus.textContent = statusText;
        resultStatus.className = 'cek-status-badge ' + statusClass(statusText);
      }
      cekResult.style.display = 'block';
    } catch (err) {
      cekError.textContent = 'Terjadi kesalahan: ' + err.message;
      cekError.style.display = 'block';
    } finally {
      if (searchBtnText) searchBtnText.style.display = 'inline';
      if (searchBtnLoading) searchBtnLoading.style.display = 'none';
      searchBtn.disabled = false;
    }
  }

  searchBtn?.addEventListener('click', cariPendaftaran);
  kodeInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      cariPendaftaran();
    }
  });
</script>

<style>
  /* ===== DROPDOWN WRAPPER (Desktop) ===== */
  .navbar__item--dropdown {
    position: relative;
  }

  .navbar__dropdown-wrapper {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .navbar__dropdown-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 0;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .navbar__dropdown-toggle:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .navbar.is-scrolled .navbar__dropdown-toggle:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  .navbar__chevron {
    transition: transform 0.25s ease;
  }

  .navbar__item--dropdown.is-open .navbar__chevron {
    transform: rotate(180deg);
  }

  /* ===== DROPDOWN MENU (Desktop) ===== */
  .navbar__dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 220px;
    background: var(--color-white);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
  }

  .navbar__item--dropdown.is-open .navbar__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .navbar__dropdown-link {
    display: block;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-dark);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .navbar__dropdown-link:hover {
    background: var(--color-bg, #f1f5f9);
    color: var(--color-primary, #2563eb);
  }

  /* ===== NAVBAR UTAMA ===== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: transparent;
    transition: background var(--transition-base, 0.3s), box-shadow var(--transition-base, 0.3s), padding var(--transition-base, 0.3s);
    padding-block: 22px;
  }

  .navbar.is-scrolled {
    background: var(--color-white);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    padding-block: 14px;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
  }

  .navbar__brand-text {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-white);
    transition: color var(--transition-base, 0.3s);
    letter-spacing: 0.02em;
  }

  .navbar.is-scrolled .navbar__brand-text {
    color: var(--color-dark);
  }

  .navbar__menu ul {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
    padding-block: 6px;
    transition: color 0.2s;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0%;
    height: 2px;
    background: var(--color-accent, #3b82f6);
    border-radius: 2px;
    transition: width 0.25s ease;
  }

  .navbar__link:hover,
  .navbar__link.is-active {
    color: var(--color-white);
  }

  .navbar__link:hover::after,
  .navbar__link.is-active::after {
    width: 100%;
  }

  .navbar.is-scrolled .navbar__link {
    color: var(--color-dark);
  }

  .navbar.is-scrolled .navbar__link:hover,
  .navbar.is-scrolled .navbar__link.is-active {
    color: var(--color-primary, #2563eb);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ===== TOMBOL CEK STATUS ===== */
  .navbar__cek-btn {
    background: #2563eb;
    color: #ffffff;
    border: none;
    padding: 9px 18px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }

  .navbar__cek-btn:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .navbar__toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-white);
    transition: background 0.2s;
  }

  .navbar.is-scrolled .navbar__toggle span {
    background: var(--color-dark);
  }

  /* ===== MODAL CEK STATUS ===== */
  .cek-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .cek-modal.is-open {
    display: flex;
  }
  .cek-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(2px);
  }
  .cek-modal__card {
    position: relative;
    background: #ffffff;
    border-radius: 16px;
    padding: 32px 28px;
    max-width: 460px;
    width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    animation: cekModalIn 0.2s ease;
  }
  @keyframes cekModalIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .cek-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #f1f5f9;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 0.95rem;
    color: #64748b;
    transition: background 0.2s;
  }
  .cek-modal__close:hover {
    background: #e2e8f0;
    color: #0f172a;
  }
  .cek-modal__title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px 0;
  }
  .cek-modal__subtitle {
    color: #64748b;
    font-size: 0.88rem;
    margin: 0 0 20px 0;
  }

  .cek-search {
    display: flex;
    gap: 10px;
  }
  .cek-search__input {
    flex: 1;
    padding: 12px 14px;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
    font-size: 0.95rem;
    font-family: inherit;
  }
  .cek-search__input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
  }
  .cek-search__btn {
    padding: 12px 20px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .cek-search__btn:hover:not(:disabled) {
    background: #1d4ed8;
  }
  .cek-search__btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .cek-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.85rem;
    margin-top: 14px;
  }

  .cek-result {
    margin-top: 20px;
    background: #f8fafc;
    border-radius: 12px;
    padding: 16px 18px;
  }
  .cek-result__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #edf2f7;
  }
  .cek-result__row:last-of-type {
    border-bottom: none;
  }
  .cek-result__label {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 600;
  }
  .cek-result__value {
    font-size: 0.92rem;
    font-weight: 600;
    color: #0f172a;
  }

  .cek-status-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .cek-status-badge--pending {
    background: #fef3c7;
    color: #92400e;
  }
  .cek-status-badge--review {
    background: #dbeafe;
    color: #1e40af;
  }
  .cek-status-badge--success {
    background: #d1fae5;
    color: #065f46;
  }
  .cek-status-badge--danger {
    background: #fee2e2;
    color: #991b1b;
  }

  /* ===== RESPONSIVE (Mobile) ===== */
  @media (max-width: 900px) {
    .navbar__toggle {
      display: flex;
    }

    .navbar__cek-btn {
      padding: 8px 12px;
      font-size: 0.8rem;
    }

    .navbar__menu {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: min(320px, 80vw);
      background: var(--color-white);
      box-shadow: var(--shadow-lg);
      padding: 100px 32px 32px;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .navbar__menu.is-open {
      transform: translateX(0);
    }

    .navbar__menu ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      width: 100%;
    }

    .navbar__link {
      color: var(--color-dark) !important;
      font-size: 1.05rem;
      width: 100%;
      justify-content: space-between;
    }

    .navbar__link::after {
      bottom: -4px;
    }

    .navbar__item--dropdown {
      width: 100%;
    }

    .navbar__dropdown-wrapper {
      width: 100%;
      position: relative;
    }

    .navbar__dropdown-toggle {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    .navbar__dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      box-shadow: none;
      background: var(--color-bg, #f8fafc);
      margin-top: 4px;
      padding: 4px;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      width: 100%;
      transform: none;
    }

    .navbar__item--dropdown.is-open .navbar__dropdown {
      max-height: 200px;
    }
  }
</style>