---
// =============================================================
// components/Footer.astro
// Footer client‑side: data diambil dari Supabase di browser.
// =============================================================
---

<footer class="footer">
  <div class="container footer__inner">
    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo-link">
        <img src="/images/logo.png" alt="Logo KKA" class="footer__logo" id="footerLogo" />
        <span>Kompetisi Kompetensi Akademik</span>
      </a>
      <p class="footer__tagline" id="footerTagline">Memuat...</p>
    </div>

    <!-- Quick Links (diisi ulang oleh JS) -->
    <div class="footer__col">
      <h4>Quick Links</h4>
      <ul id="footerQuickLinks">
        <li><a href="/">Beranda</a></li>
        <li><a href="/informasi">Informasi</a></li>
        <li><a href="/tentang">Tentang</a></li>
      </ul>
    </div>

    <!-- Kontak -->
    <div class="footer__col">
      <h4>Kontak</h4>
      <ul class="footer__contact">
        <li id="footerAlamat">Memuat...</li>
        <li id="footerEmail">Memuat...</li>
        <li id="footerTelepon">Memuat...</li>
      </ul>
    </div>

    <!-- Sosial Media -->
    <div class="footer__col">
      <h4>Ikuti Kami</h4>
      <div class="footer__social" id="footerSocialIcons">
        <!-- Diisi oleh JS -->
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; <span id="footerYear"></span> Kompetisi Kompetensi Akademik. Seluruh hak cipta dilindungi.</p>
    </div>
  </div>
</footer>

<script type="module">
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  async function loadFooter() {
    // --- Footer Content ---
    try {
      const { data: footer } = await supabase.from('footer_content').select('*').single();
      if (footer) {
        if (footer.logo_url) {
          document.getElementById('footerLogo').src = footer.logo_url;
        }
        document.getElementById('footerTagline').textContent = footer.tagline || '';
        document.getElementById('footerAlamat').textContent = footer.alamat || '';
        document.getElementById('footerEmail').textContent = footer.email || '';
        document.getElementById('footerTelepon').textContent = footer.telepon || '';
      }
    } catch (err) {
      console.warn('Gagal memuat footer content:', err);
    }

    // --- Quick Links (dari navbar_menus) ---
    try {
      const { data: quickLinks } = await supabase
        .from('navbar_menus')
        .select('label, href')
        .order('urutan', { ascending: true });

      const quickLinksContainer = document.getElementById('footerQuickLinks');
      if (quickLinks && quickLinks.length > 0) {
        quickLinksContainer.innerHTML = quickLinks.map(link =>
          `<li><a href="${link.href}">${link.label}</a></li>`
        ).join('');
      }
    } catch (err) {
      console.warn('Gagal memuat quick links:', err);
    }

    // --- Sosial Media ---
    try {
      const { data: socialLinks } = await supabase
        .from('footer_social_links')
        .select('*')
        .order('urutan', { ascending: true });

      const socialContainer = document.getElementById('footerSocialIcons');
      if (socialLinks && socialLinks.length > 0) {
        socialContainer.innerHTML = socialLinks.map(social =>
          `<a href="${social.href}" aria-label="${social.label}" class="footer__social-link">
            <span aria-hidden="true">${social.icon || '🌐'}</span>
          </a>`
        ).join('');
      }
    } catch (err) {
      console.warn('Gagal memuat social links:', err);
    }

    // --- Tahun ---
    document.getElementById('footerYear').textContent = new Date().getFullYear();
  }

  loadFooter();
</script>

<style>
  .footer {
    background: var(--color-dark);
    color: rgba(248, 250, 252, 0.75);
    padding-top: 72px;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-white);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .footer__logo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
  }

  .footer__tagline {
    font-size: 0.9rem;
    line-height: 1.7;
    max-width: 320px;
  }

  .footer__col h4 {
    color: var(--color-white);
    font-size: 0.95rem;
    margin-bottom: 18px;
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col a {
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .footer__col a:hover {
    color: var(--color-accent);
  }

  .footer__contact li {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__social {
    display: flex;
    gap: 10px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .footer__social-link:hover {
    background: var(--color-accent);
    transform: translateY(-3px);
  }

  .footer__bottom {
    padding-block: 24px;
  }

  .footer__bottom-inner {
    text-align: center;
    font-size: 0.85rem;
    color: rgba(248, 250, 252, 0.5);
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>