---
// =============================================================
// components/Information.astro
// Section "Informasi" – client‑side fetching dari Supabase
// =============================================================
---

<section class="information section" id="informasi">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Informasi Kompetisi</span>
      <h2 class="section-title">Semua yang Perlu Anda Ketahui</h2>
      <p class="section-subtitle mx-auto">
        Simak informasi penting seputar jenjang peserta, jadwal, lokasi, dan persyaratan sebelum
        melakukan pendaftaran.
      </p>
    </div>

    <!-- Loading state -->
    <div id="infoLoading" class="information__empty">
      <span class="text-2xl block mb-2">⏳</span>
      Memuat informasi...
    </div>

    <!-- Empty state -->
    <div id="infoEmpty" class="information__empty" style="display:none;">
      <span class="text-2xl block mb-2">📋</span>
      Informasi belum tersedia.
    </div>

    <!-- Error state -->
    <div id="infoError" class="information__empty" style="display:none; color:#dc2626;"></div>

    <!-- Grid, diisi via JS -->
    <div class="information__grid" id="infoGrid" style="display:none;"></div>

    <!-- CTA -->
    <div class="information__cta" id="infoCta" style="display:none;">
      <a href="/informasi" class="btn btn-secondary">Lihat Selengkapnya</a>
    </div>
  </div>
</section>

<script type="module">
  import { supabase } from '../lib/supabase';

  const loadingEl = document.getElementById('infoLoading');
  const emptyEl = document.getElementById('infoEmpty');
  const errorEl = document.getElementById('infoError');
  const gridEl = document.getElementById('infoGrid');
  const ctaEl = document.getElementById('infoCta');

  function escapeHtml(str) {
    return String(str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function renderGrid(items) {
    // CATATAN: class "reveal"/"reveal-delay-X" SENGAJA tidak dipakai di sini.
    // Elemen ini muncul async setelah fetch selesai, sehingga
    // IntersectionObserver scroll-animation global (yang hanya observe
    // elemen yang ada saat DOMContentLoaded) tidak pernah "melihat" elemen
    // ini -> opacity tetap 0 selamanya walau datanya ada. Menghapus class
    // ini di sumbernya jauh lebih sederhana & stabil dibanding menambal
    // dengan fallback ScrollReveal.sync() atau setTimeout manual.
    gridEl.innerHTML = items.map((card) => `
      <div class="information__card card">
        <span class="information__icon">${escapeHtml(card.icon) || '📄'}</span>
        <h3 class="information__label">${escapeHtml(card.label)}</h3>
        <ul class="information__list">
          ${(card.items || []).map((item) => `<li>${escapeHtml(item)}</li>`).join('')}
        </ul>
      </div>
    `).join('');

    ctaEl.style.display = 'block';
  }

  async function loadInformation() {
    loadingEl.style.display = 'block';
    emptyEl.style.display = 'none';
    errorEl.style.display = 'none';
    gridEl.style.display = 'none';
    ctaEl.style.display = 'none';

    try {
      const { data, error } = await supabase
        .from('informasi_kartu')
        .select('*')
        .order('urutan', { ascending: true });

      if (error) throw error;

      loadingEl.style.display = 'none';

      if (!data || data.length === 0) {
        emptyEl.style.display = 'block';
        return;
      }

      gridEl.style.display = 'grid';
      renderGrid(data);
    } catch (err) {
      console.error('Gagal fetch informasi:', err);
      loadingEl.style.display = 'none';
      errorEl.textContent = `❌ Gagal memuat informasi: ${err.message || err}`;
      errorEl.style.display = 'block';
    }
  }

  loadInformation();
</script>

<style>
  /* PENTING: elemen di dalam #infoGrid dibuat lewat innerHTML, jadi TIDAK
     mendapat atribut scoping otomatis dari Astro. Semua selector untuk
     elemen tersebut WAJIB dibungkus :global(...) supaya CSS ini benar-benar
     berlaku, kalau tidak kartu informasi akan tampil polos tanpa styling. */

  :global(.information__grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .information__empty {
    text-align: center;
    color: var(--color-gray);
    padding: 40px 0;
  }

  :global(.information__card) {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  :global(.information__icon) {
    font-size: 1.8rem;
  }

  :global(.information__label) {
    font-size: 1.05rem;
  }

  :global(.information__list) {
    padding-left: 18px;
    color: var(--color-gray);
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .information__cta {
    text-align: center;
    margin-top: 40px;
  }

  @media (max-width: 900px) {
    :global(.information__grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    :global(.information__grid) {
      grid-template-columns: 1fr;
    }
  }
</style>