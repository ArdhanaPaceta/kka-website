---
// =============================================================
// components/admin/InformasiForm.astro
// Panel ADMIN untuk kelola Kartu Informasi (client‑side, Tailwind)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-7">
    <div>
      <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola Informasi</h2>
      <p class="text-slate-500 text-sm m-0 leading-snug">Atur kartu-kartu informasi (Jenjang, Tanggal Penting, Lokasi, dll) yang tampil di halaman publik.</p>
    </div>
    <button type="button" id="btnTambahKartu" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-emerald-600 to-emerald-700 text-black font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(16,185,129,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(16,185,129,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap">
      <span class="text-lg leading-none">+</span> Tambah Kartu
    </button>
  </div>

  <!-- Error banner -->
  <div id="infoErrorBanner" class="hidden items-start gap-2.5 bg-red-50 border border-red-200 px-4 py-3.5 rounded-[10px] mb-6">
    <span class="text-lg leading-snug">⚠️</span>
    <div>
      <p class="m-0 text-red-700 text-sm leading-snug"><strong>Gagal memuat data:</strong> <span id="infoErrorMsg"></span></p>
      <p class="text-[0.82rem] text-red-800 mt-1">Pastikan tabel "informasi_kartu" ada dan RLS mengizinkan SELECT.</p>
    </div>
  </div>

  <!-- Loading state -->
  <div id="infoLoadingState" class="text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-[1.8rem] mb-2">⏳</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Memuat data informasi...</p>
  </div>

  <!-- List kartu (diisi via JS) -->
  <div id="infoList" class="hidden flex-col gap-2.5 mb-6"></div>

  <!-- Empty state -->
  <div id="infoEmptyState" class="hidden text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <span class="text-2xl mb-2 block">📋</span>
    <p class="font-semibold text-slate-700 m-0 mb-1">Belum ada kartu informasi.</p>
    <span class="text-sm text-slate-400">Klik tombol "Tambah Kartu" untuk mulai.</span>
  </div>

  <!-- Form Tambah/Edit -->
  <form id="infoForm" class="hidden overflow-hidden max-h-0 opacity-0 -translate-y-1.5 transition-all duration-300 ease-in-out">
    <hr class="border-0 border-t-2 border-slate-200 my-2 mb-5" />
    <h3 id="infoFormTitle" class="text-[1.1rem] font-bold text-slate-900 mb-5">Tambah Kartu Informasi</h3>
    <input type="hidden" id="infoId" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="iLabel" class="font-semibold text-[0.87rem] text-slate-800">Label / Judul Kartu</label>
        <input type="text" id="iLabel" placeholder="Contoh: Jenjang" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="iUrutan" class="font-semibold text-[0.87rem] text-slate-800">Urutan Tampil</label>
        <input type="number" id="iUrutan" value="0" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <label for="iIcon" class="font-semibold text-[0.87rem] text-slate-800">Icon (emoji)</label>
      <input type="text" id="iIcon" placeholder="📚" maxlength="4"
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      <small class="text-slate-400 text-[0.78rem] mt-0.5">Contoh: 📚, 🗓️, 📍, ✅ (opsional)</small>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <label for="iItems" class="font-semibold text-[0.87rem] text-slate-800">Daftar Poin (satu poin per baris)</label>
      <textarea id="iItems" rows="5" placeholder="Sekolah Dasar (SD)&#10;Sekolah Menengah Pertama (SMP)&#10;Sekolah Menengah Kejuruan (SMK)" required
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.9rem] bg-white resize-y min-h-[120px] font-mono focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"></textarea>
      <small class="text-slate-400 text-[0.78rem] mt-0.5">Setiap baris menjadi satu poin dalam daftar.</small>
    </div>

    <p id="iStatus" class="font-medium text-sm rounded-lg transition mb-4"></p>

    <div class="flex gap-3 flex-wrap">
      <button type="button" id="btnBatalKartu" class="bg-transparent border border-slate-300 text-slate-600 px-5 py-2.5 rounded-xl font-medium hover:bg-slate-100 hover:border-slate-400 transition">Batal</button>
      <button type="submit" class="inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-emerald-600 to-emerald-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(16,185,129,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(16,185,129,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">Simpan Kartu</button>
    </div>
  </form>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  // --- DOM Elements ---
  const btnTambahKartu = document.getElementById('btnTambahKartu');
  const infoForm = document.getElementById('infoForm');
  const btnBatalKartu = document.getElementById('btnBatalKartu');
  const infoFormTitle = document.getElementById('infoFormTitle');
  const infoId = document.getElementById('infoId');
  const iStatus = document.getElementById('iStatus');
  const infoListEl = document.getElementById('infoList');
  const infoEmptyState = document.getElementById('infoEmptyState');
  const infoLoadingState = document.getElementById('infoLoadingState');
  const errorBanner = document.getElementById('infoErrorBanner');
  const errorMsg = document.getElementById('infoErrorMsg');

  // --- State Management ---
  function showError(msg) {
    errorMsg.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.classList.add('flex');
  }

  function hideError() {
    errorBanner.classList.add('hidden');
    errorBanner.classList.remove('flex');
  }

  function showLoading() {
    infoLoadingState.classList.remove('hidden');
    infoListEl.classList.add('hidden');
    infoListEl.classList.remove('flex');
    infoEmptyState.classList.add('hidden');
  }

  function showList() {
    infoLoadingState.classList.add('hidden');
    infoListEl.classList.remove('hidden');
    infoListEl.classList.add('flex');
    infoEmptyState.classList.add('hidden');
  }

  function showEmpty() {
    infoLoadingState.classList.add('hidden');
    infoListEl.classList.add('hidden');
    infoListEl.classList.remove('flex');
    infoEmptyState.classList.remove('hidden');
  }

  function resetForm() {
    infoForm.reset();
    infoId.value = '';
    infoFormTitle.textContent = 'Tambah Kartu Informasi';
    document.getElementById('iUrutan').value = 0;
    iStatus.textContent = '';
    iStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
  }

  function setStatus(msg, type) {
    iStatus.textContent = msg;
    iStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
    if (type === 'error') iStatus.classList.add('text-red-700', 'bg-red-50', 'px-3', 'py-2.5');
    else if (type === 'success') iStatus.classList.add('text-emerald-800', 'bg-emerald-100', 'px-3', 'py-2.5');
    else if (type === 'loading') iStatus.classList.add('text-blue-800', 'bg-blue-100', 'px-3', 'py-2.5');
  }

  // --- Load Data ---
  async function loadData() {
    showLoading();
    hideError();
    try {
      const { data, error } = await supabase
        .from('informasi_kartu')
        .select('*')
        .order('urutan', { ascending: true });

      if (error) throw error;

      if (!data || data.length === 0) {
        showEmpty();
        return;
      }

      renderList(data);
      showList();
    } catch (err) {
      console.error('Gagal fetch informasi:', err);
      showError(err.message);
    }
  }

  function renderList(items) {
    infoListEl.innerHTML = items.map((item) => {
      const itemsList = (item.items || []).map((point) => `<li>${point}</li>`).join('');
      return `
        <div class="flex items-start flex-wrap sm:flex-nowrap gap-3.5 px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-100 hover:bg-slate-100/60 hover:border-slate-200 hover:shadow-[0_2px_8px_rgba(15,23,42,0.04)] transition" data-id="${item.id}">
          <div class="flex-1 min-w-[150px]">
            <div class="flex items-center flex-wrap gap-2 mb-2">
              <span class="text-lg">${item.icon || '📄'}</span>
              <strong class="text-[0.98rem] text-slate-900">${item.label}</strong>
              <span class="bg-indigo-50 text-blue-600 text-[0.7rem] font-bold px-2.5 py-0.5 rounded-full tracking-wide">Urutan #${item.urutan}</span>
            </div>
            <ul class="list-disc pl-5 text-[0.87rem] text-slate-600 space-y-0.5">
              ${itemsList}
            </ul>
          </div>
          <div class="flex gap-1.5 flex-shrink-0 w-full justify-end sm:w-auto mt-2 sm:mt-0">
            <button type="button" class="btn-edit-info text-emerald-600 bg-emerald-50 hover:bg-emerald-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1"
              data-id="${item.id}" data-label="${item.label}" data-icon="${item.icon || ''}" data-urutan="${item.urutan}" data-items='${JSON.stringify(item.items || [])}'>
               <span>Edit</span>
            </button>
            <button type="button" class="btn-delete-info text-red-600 bg-red-50 hover:bg-red-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1" data-id="${item.id}">
              <span>Hapus</span>
            </button>
          </div>
        </div>
      `;
    }).join('');

    attachRowEvents();
  }

  function attachRowEvents() {
    // Edit
    infoListEl.querySelectorAll('.btn-edit-info').forEach((btn) => {
      btn.addEventListener('click', () => {
        infoId.value = btn.dataset.id;
        document.getElementById('iLabel').value = btn.dataset.label;
        document.getElementById('iIcon').value = btn.dataset.icon || '';
        document.getElementById('iUrutan').value = btn.dataset.urutan;

        const items = JSON.parse(btn.dataset.items || '[]');
        document.getElementById('iItems').value = items.join('\n');

        infoFormTitle.textContent = 'Edit Kartu Informasi';
        openForm();
        document.getElementById('iLabel').focus();
        setStatus('', '');
      });
    });

    // Delete
    infoListEl.querySelectorAll('.btn-delete-info').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Yakin ingin menghapus kartu informasi ini?')) return;
        const id = btn.dataset.id;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '⏳ <span>Menghapus...</span>';
        btn.disabled = true;

        try {
          const { error } = await supabase.from('informasi_kartu').delete().eq('id', id);
          if (error) throw error;
          await loadData();
        } catch (err) {
          alert('Gagal menghapus: ' + err.message);
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    });
  }

  // --- Form Toggle ---
  function openForm() {
    infoForm.classList.remove('hidden');
    requestAnimationFrame(() => {
      infoForm.classList.remove('max-h-0', 'opacity-0', '-translate-y-1.5');
      infoForm.classList.add('max-h-[900px]', 'opacity-100', 'translate-y-0');
    });
    infoForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function closeForm() {
    infoForm.classList.remove('max-h-[900px]', 'opacity-100', 'translate-y-0');
    infoForm.classList.add('max-h-0', 'opacity-0', '-translate-y-1.5');
    setTimeout(() => {
      infoForm.classList.add('hidden');
      resetForm();
    }, 200);
  }

  btnTambahKartu.addEventListener('click', () => {
    resetForm();
    openForm();
    document.getElementById('iLabel').focus();
  });

  btnBatalKartu.addEventListener('click', closeForm);

  // --- Submit ---
  infoForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const label = document.getElementById('iLabel').value.trim();
    const icon = document.getElementById('iIcon').value.trim();
    const urutan = parseInt(document.getElementById('iUrutan').value || '0', 10);
    const itemsRaw = document.getElementById('iItems').value;

    const items = itemsRaw
      .split('\n')
      .map((line) => line.trim())
      .filter((line) => line.length > 0);

    if (!label) {
      setStatus('⚠️ Label/judul kartu wajib diisi.', 'error');
      return;
    }

    if (items.length === 0) {
      setStatus('⚠️ Isi minimal satu poin.', 'error');
      return;
    }

    setStatus('⏳ Menyimpan...', 'loading');
    const payload = { label, icon: icon || null, urutan, items };

    try {
      let error;
      if (infoId.value) {
        ({ error } = await supabase.from('informasi_kartu').update(payload).eq('id', infoId.value));
      } else {
        ({ error } = await supabase.from('informasi_kartu').insert(payload));
      }
      if (error) throw error;

      setStatus('✅ Kartu berhasil ' + (infoId.value ? 'diperbarui' : 'ditambahkan') + '!', 'success');
      setTimeout(async () => {
        closeForm();
        resetForm();
        await loadData();
      }, 800);
    } catch (err) {
      setStatus('❌ Gagal: ' + err.message, 'error');
    }
  });

  // --- Init ---
  loadData();
</script>