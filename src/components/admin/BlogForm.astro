---
// =============================================================
// components/admin/BlogForm.astro
// Panel ADMIN untuk kelola Blog (client‑side, Tailwind)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-7">
    <div>
      <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola Blog</h2>
      <p class="text-slate-500 text-sm m-0 leading-snug">Tambah, lihat, atau hapus artikel blog yang tampil di halaman publik.</p>
    </div>
    <span id="blogCount" class="bg-indigo-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-semibold whitespace-nowrap">0 Artikel</span>
  </div>

  <!-- FORM TAMBAH -->
  <form id="blogForm" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-[2fr_1fr] gap-4">
      <div class="flex flex-col gap-1.5">
        <label for="bJudul" class="font-semibold text-[0.87rem] text-slate-800">Judul Artikel</label>
        <input type="text" id="bJudul" placeholder="Contoh: Tips Persiapan Menghadapi KKA" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="bTanggal" class="font-semibold text-[0.87rem] text-slate-800">Tanggal</label>
        <input type="date" id="bTanggal" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="bRingkasan" class="font-semibold text-[0.87rem] text-slate-800">Ringkasan (excerpt)</label>
      <textarea id="bRingkasan" rows="3" placeholder="Strategi belajar efektif agar siswa lebih percaya diri..." required
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white resize-y min-h-[75px] focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"></textarea>
    </div>

    <!-- Upload Gambar -->
    <div class="flex flex-col gap-1.5">
      <label class="font-semibold text-[0.87rem] text-slate-800">Gambar Artikel</label>
      <div id="uploadArea" class="relative border-2 border-dashed border-slate-200 rounded-xl p-6 text-center cursor-pointer transition hover:border-blue-600 hover:bg-blue-50/30 min-h-[150px] flex items-center justify-center">
        <input type="file" id="bImageFile" accept="image/*" required
          class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
        <div id="uploadPlaceholder" class="pointer-events-none">
          <span class="text-3xl block mb-1">🖼️</span>
          <p class="font-medium text-slate-700 m-0">Klik atau seret gambar ke sini</p>
          <small class="text-slate-400 text-xs">Format: JPG, PNG, WEBP (max 5MB)</small>
        </div>
        <img id="bPreview" class="hidden max-w-[200px] max-h-[150px] rounded-lg object-cover border-2 border-blue-600 shadow-lg" alt="Pratinjau gambar" />
      </div>
    </div>

    <div class="flex items-center gap-4 flex-wrap pt-2">
      <button type="submit" id="bSubmitBtn" class="inline-flex items-center gap-2 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed">
        <span class="text-lg leading-none">+</span> Tambah Artikel
      </button>
      <span id="bStatus" class="font-medium text-sm min-h-[1.8rem]"></span>
    </div>
  </form>

  <hr class="border-0 border-t-2 border-slate-200 my-5" />

  <!-- LIST ARTIKEL -->
  <div class="mb-4">
    <h3 class="text-[1.1rem] font-bold text-slate-900">Daftar Artikel</h3>
  </div>

  <!-- Error banner -->
  <div id="blogErrorBanner" class="hidden items-start gap-2.5 bg-red-50 border border-red-200 px-4 py-3.5 rounded-[10px] mb-6">
    <span class="text-lg leading-snug">⚠️</span>
    <div>
      <p class="m-0 text-red-700 text-sm leading-snug"><strong>Gagal memuat data:</strong> <span id="blogErrorMsg"></span></p>
      <p class="text-[0.82rem] text-red-800 mt-1">Pastikan tabel "blog_artikel" ada dan RLS mengizinkan SELECT.</p>
    </div>
  </div>

  <!-- Loading state -->
  <div id="blogLoadingState" class="text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-[1.8rem] mb-2">⏳</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Memuat artikel...</p>
  </div>

  <!-- List artikel (diisi via JS) -->
  <div id="blogList" class="hidden flex-col gap-3 mb-6"></div>

  <!-- Empty state -->
  <div id="blogEmptyState" class="hidden text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <span class="text-2xl mb-2 block">📝</span>
    <p class="font-semibold text-slate-700 m-0 mb-1">Belum ada artikel blog.</p>
    <span class="text-sm text-slate-400">Tambahkan artikel pertama menggunakan form di atas.</span>
  </div>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  const BUCKET = 'blog';

  // --- DOM Elements ---
  const blogForm = document.getElementById('blogForm');
  const bStatus = document.getElementById('bStatus');
  const bImageFile = document.getElementById('bImageFile');
  const bPreview = document.getElementById('bPreview');
  const bSubmitBtn = document.getElementById('bSubmitBtn');
  const uploadArea = document.getElementById('uploadArea');
  const uploadPlaceholder = document.getElementById('uploadPlaceholder');
  const blogCount = document.getElementById('blogCount');

  const blogListEl = document.getElementById('blogList');
  const blogEmptyState = document.getElementById('blogEmptyState');
  const blogLoadingState = document.getElementById('blogLoadingState');
  const errorBanner = document.getElementById('blogErrorBanner');
  const errorMsg = document.getElementById('blogErrorMsg');

  // --- State Management ---
  function showError(msg) {
    errorMsg.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.classList.add('flex');
  }

  function hideError() {
    errorBanner.classList.add('hidden');
    errorBanner.classList.remove('flex');
  }

  function showLoading() {
    blogLoadingState.classList.remove('hidden');
    blogListEl.classList.add('hidden');
    blogListEl.classList.remove('flex');
    blogEmptyState.classList.add('hidden');
  }

  function showList() {
    blogLoadingState.classList.add('hidden');
    blogListEl.classList.remove('hidden');
    blogListEl.classList.add('flex');
    blogEmptyState.classList.add('hidden');
  }

  function showEmpty() {
    blogLoadingState.classList.add('hidden');
    blogListEl.classList.add('hidden');
    blogListEl.classList.remove('flex');
    blogEmptyState.classList.remove('hidden');
  }

  function setStatus(msg, type) {
    bStatus.textContent = msg;
    bStatus.className = 'font-medium text-sm min-h-[1.8rem]';
    if (type === 'error') bStatus.classList.add('text-red-600');
    else if (type === 'success') bStatus.classList.add('text-emerald-700');
    else if (type === 'loading') bStatus.classList.add('text-blue-600');
  }

  // --- Set tanggal default ---
  document.getElementById('bTanggal').value = new Date().toISOString().split('T')[0];

  // --- Preview gambar ---
  bImageFile.addEventListener('change', () => {
    const file = bImageFile.files?.[0];
    if (file) {
      bPreview.src = URL.createObjectURL(file);
      bPreview.classList.remove('hidden');
      uploadPlaceholder.classList.add('hidden');
    } else {
      bPreview.classList.add('hidden');
      uploadPlaceholder.classList.remove('hidden');
    }
  });

  // --- Drag and drop ---
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-blue-600', 'bg-blue-50/50');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('border-blue-600', 'bg-blue-50/50');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-blue-600', 'bg-blue-50/50');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      bImageFile.files = files;
      bImageFile.dispatchEvent(new Event('change'));
    }
  });

  // --- Load Artikel ---
  async function loadArticles() {
    showLoading();
    hideError();
    try {
      const { data, error } = await supabase
        .from('blog_artikel')
        .select('*')
        .order('tanggal', { ascending: false });

      if (error) throw error;

      blogCount.textContent = `${data?.length || 0} Artikel`;

      if (!data || data.length === 0) {
        showEmpty();
        return;
      }

      renderList(data);
      showList();
    } catch (err) {
      console.error('Gagal fetch artikel:', err);
      showError(err.message);
    }
  }

  function renderList(items) {
    blogListEl.innerHTML = items.map((item) => `
      <div class="flex gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100 hover:bg-slate-100/60 hover:border-slate-200 hover:shadow-[0_2px_8px_rgba(15,23,42,0.04)] transition items-start flex-wrap sm:flex-nowrap" data-id="${item.id}">
        <div class="flex-shrink-0 w-[120px] h-[90px] rounded-lg overflow-hidden bg-slate-200 sm:w-[120px] w-full sm:h-[90px] h-[150px]">
          <img src="${item.gambar}" alt="${item.judul}" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex-1 flex flex-col gap-1 min-w-[150px]">
          <strong class="text-[0.98rem] text-slate-900">${item.judul}</strong>
          <span class="text-slate-500 text-xs">📅 ${new Date(item.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          <p class="text-slate-600 text-[0.87rem] mt-0.5 leading-snug line-clamp-2">${item.ringkasan}</p>
        </div>
        <button type="button" class="btn-delete-blog text-red-600 bg-red-50 hover:bg-red-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1 flex-shrink-0 w-full sm:w-auto justify-center"
          data-id="${item.id}" data-path="${item.path_gambar || ''}">
          🗑️ <span>Hapus</span>
        </button>
      </div>
    `).join('');

    attachDeleteEvents();
  }

  function attachDeleteEvents() {
    blogListEl.querySelectorAll('.btn-delete-blog').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Hapus artikel ini?')) return;

        const id = btn.dataset.id;
        const path = btn.dataset.path;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '⏳ <span>Menghapus...</span>';
        btn.disabled = true;

        try {
          const { error: dbError } = await supabase.from('blog_artikel').delete().eq('id', id);
          if (dbError) throw dbError;

          if (path) {
            await supabase.storage.from(BUCKET).remove([path]);
          }

          await loadArticles();
        } catch (err) {
          alert('Gagal menghapus: ' + err.message);
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    });
  }

  // --- Submit Artikel ---
  blogForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const file = bImageFile.files?.[0];
    if (!file) {
      setStatus('⚠️ Silakan pilih gambar terlebih dahulu.', 'error');
      return;
    }

    if (file.size > 5 * 1024 * 1024) {
      setStatus('⚠️ Ukuran gambar maksimal 5MB.', 'error');
      return;
    }

    bSubmitBtn.disabled = true;
    setStatus('⏳ Mengunggah gambar...', 'loading');

    try {
      const ext = file.name.split('.').pop();
      const fileName = `${crypto.randomUUID()}.${ext}`;

      const { error: uploadError } = await supabase.storage
        .from(BUCKET)
        .upload(fileName, file);

      if (uploadError) throw new Error('Upload gagal: ' + uploadError.message);

      const { data: publicUrlData } = supabase.storage
        .from(BUCKET)
        .getPublicUrl(fileName);

      const payload = {
        judul: document.getElementById('bJudul').value.trim(),
        tanggal: document.getElementById('bTanggal').value,
        ringkasan: document.getElementById('bRingkasan').value.trim(),
        gambar: publicUrlData.publicUrl,
        path_gambar: fileName,
      };

      const { error: insertError } = await supabase.from('blog_artikel').insert(payload);

      if (insertError) {
        // Hapus file yang sudah terupload jika insert gagal
        await supabase.storage.from(BUCKET).remove([fileName]);
        throw new Error('Gagal menyimpan: ' + insertError.message);
      }

      setStatus('✅ Artikel berhasil ditambahkan!', 'success');
      blogForm.reset();
      bPreview.classList.add('hidden');
      uploadPlaceholder.classList.remove('hidden');
      document.getElementById('bTanggal').value = new Date().toISOString().split('T')[0];
      
      setTimeout(async () => {
        setStatus('', '');
        await loadArticles();
      }, 1000);
    } catch (err) {
      setStatus('❌ ' + err.message, 'error');
    } finally {
      bSubmitBtn.disabled = false;
    }
  });

  // --- Init ---
  loadArticles();
</script>