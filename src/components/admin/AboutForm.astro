---
// =============================================================
// components/admin/AboutForm.astro
// Panel ADMIN untuk kelola kartu keunggulan (teks saja)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col items-stretch gap-4 mb-7 sm:flex-row sm:items-start sm:justify-between sm:flex-wrap">
    <div class="flex items-start gap-3.5">
      <div class="flex-shrink-0 w-[42px] h-[42px] rounded-xl bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center text-xl shadow-[0_4px_10px_rgba(37,99,235,0.25)]">
        ✨
      </div>
      <div>
        <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola About (Keunggulan)</h2>
        <p class="text-slate-500 text-sm m-0 leading-snug">Atur kartu keunggulan yang tampil di section "Tentang Kompetisi".</p>
      </div>
    </div>
    <button
      type="button"
      id="about-btnTambah"
      class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-black font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0 whitespace-nowrap"
    >
      <span class="text-lg leading-none">+</span> Tambah Keunggulan
    </button>
  </div>

  <div id="about-errorBanner" class="hidden items-start gap-2.5 bg-red-50 border border-red-200 px-4 py-3.5 rounded-[10px] mb-6">
    <span class="text-lg leading-snug">⚠️</span>
    <div>
      <p class="m-0 text-red-700 text-sm leading-snug"><strong>Gagal memuat data:</strong> <span id="about-errorMsg"></span></p>
      <p class="text-[0.82rem] text-red-800 mt-1">Pastikan tabel "keunggulan" ada dan RLS mengizinkan SELECT.</p>
    </div>
  </div>

  <div id="about-loadingState" class="text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-[1.8rem] mb-2">⏳</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Memuat data...</p>
  </div>

  <div id="about-itemList" class="hidden flex-col gap-2.5 mb-6"></div>

  <div id="about-emptyState" class="hidden text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-2xl mb-2">📋</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Belum ada data keunggulan.</p>
    <span class="text-sm text-slate-400">Klik tombol "Tambah Keunggulan" untuk mulai.</span>
  </div>

  <form id="about-itemForm" class="hidden overflow-hidden max-h-0 opacity-0 -translate-y-1.5 transition-all duration-300 ease-in-out">
    <div class="pt-1">
      <hr class="border-0 border-t-2 border-slate-200 my-2 mb-5" />
      <h3 id="about-formTitle" class="text-[1.1rem] font-bold text-slate-900 mb-5 flex items-center gap-1.5">📝 Tambah Keunggulan</h3>
      <input type="hidden" id="about-itemId" />

      <div class="grid grid-cols-1 sm:grid-cols-[2fr_1fr] gap-0 sm:gap-4">
        <div class="flex flex-col gap-1.5 mb-4">
          <label for="about-judul" class="font-semibold text-[0.87rem] text-slate-800 flex items-center justify-between">
            Judul <span class="text-red-600">*</span>
          </label>
          <input
            type="text" id="about-judul" name="judul" placeholder="Contoh: Kompetisi Adil" required maxlength="80"
            class="w-full box-border px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white font-inherit focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"
          />
        </div>
        <div class="flex flex-col gap-1.5 mb-4">
          <label for="about-urutan" class="font-semibold text-[0.87rem] text-slate-800 flex items-center justify-between">
            Urutan Tampil <span class="text-red-600">*</span>
          </label>
          <input
            type="number" id="about-urutan" name="urutan" value="1" min="1" required
            class="w-full box-border px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white font-inherit focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"
          />
        </div>
      </div>

      <div class="flex flex-col gap-1.5 mb-4">
        <label for="about-deskripsi" class="font-semibold text-[0.87rem] text-slate-800 flex items-center justify-between">
          <span>Deskripsi <span class="text-red-600">*</span></span>
          <span class="char-count font-medium text-xs text-slate-400" id="about-charCount">0/200</span>
        </label>
        <textarea
          id="about-deskripsi" name="deskripsi" rows="3" maxlength="200" placeholder="Tulis deskripsi keunggulan di sini..." required
          class="w-full box-border px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white font-inherit resize-y min-h-[75px] focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"
        ></textarea>
      </div>

      <!-- Tidak ada lagi upload gambar -->
      <div id="about-itemStatus" class="font-medium text-sm rounded-lg transition"></div>

      <div class="flex gap-3 mt-2 flex-wrap">
        <button type="button" id="about-btnBatal" class="bg-transparent border border-slate-300 text-slate-600 px-5 py-2.5 rounded-xl font-medium hover:bg-slate-100 hover:border-slate-400 transition">Batal</button>
        <button type="submit" id="about-btnSubmit" class="inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">
          <span class="btn-text">Simpan Data</span>
          <span class="btn-loading hidden items-center gap-1.5">
            <span class="w-[13px] h-[13px] border-2 border-white/40 border-t-white rounded-full inline-block animate-spin"></span>
            Menyimpan...
          </span>
        </button>
      </div>
    </div>
  </form>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  // DOM Elements
  const btnTambah = document.getElementById('about-btnTambah');
  const itemForm = document.getElementById('about-itemForm');
  const btnBatal = document.getElementById('about-btnBatal');
  const btnSubmit = document.getElementById('about-btnSubmit');
  const formTitle = document.getElementById('about-formTitle');
  const itemId = document.getElementById('about-itemId');
  const statusEl = document.getElementById('about-itemStatus');
  const deskripsiEl = document.getElementById('about-deskripsi');
  const charCount = document.getElementById('about-charCount');

  const itemListEl = document.getElementById('about-itemList');
  const emptyStateEl = document.getElementById('about-emptyState');
  const loadingStateEl = document.getElementById('about-loadingState');
  const errorBannerEl = document.getElementById('about-errorBanner');
  const errorMsgEl = document.getElementById('about-errorMsg');

  const submitText = btnSubmit.querySelector('.btn-text');
  const submitLoading = btnSubmit.querySelector('.btn-loading');

  // --- Fetch & Render List (tanpa gambar) ---
  async function loadItems() {
    loadingStateEl.classList.remove('hidden');
    itemListEl.classList.add('hidden');
    itemListEl.classList.remove('flex');
    emptyStateEl.classList.add('hidden');
    errorBannerEl.classList.add('hidden');
    errorBannerEl.classList.remove('flex');

    try {
      const { data, error } = await supabase
        .from('keunggulan')
        .select('id, judul, deskripsi, urutan')
        .order('urutan', { ascending: true });

      if (error) throw error;

      loadingStateEl.classList.add('hidden');

      if (!data || data.length === 0) {
        emptyStateEl.classList.remove('hidden');
        return;
      }

      itemListEl.classList.remove('hidden');
      itemListEl.classList.add('flex');
      itemListEl.innerHTML = data.map((item) => `
        <div class="flex items-center flex-wrap sm:flex-nowrap gap-3.5 px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-100 hover:bg-slate-100/60 hover:border-slate-200 hover:shadow-[0_2px_8px_rgba(15,23,42,0.04)] transition" data-id="${item.id}">
          <div class="flex-1 min-w-[150px]">
            <div class="flex items-center flex-wrap gap-2 mb-1">
              <strong class="text-[0.98rem] text-slate-900">${item.judul}</strong>
              <span class="bg-indigo-50 text-blue-600 text-[0.7rem] font-bold px-2.5 py-0.5 rounded-full tracking-wide">#${item.urutan}</span>
            </div>
            <p class="text-slate-500 text-[0.87rem] mt-0.5 leading-snug line-clamp-2">${item.deskripsi}</p>
          </div>
          <div class="flex gap-1.5 flex-shrink-0 w-full justify-end sm:w-auto">
            <button type="button" class="about-btn-edit inline-flex items-center gap-1 text-blue-600 bg-blue-50 hover:bg-blue-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition"
              data-id="${item.id}"
              data-judul="${item.judul.replace(/"/g, '&quot;')}"
              data-deskripsi="${item.deskripsi.replace(/"/g, '&quot;')}"
              data-urutan="${item.urutan}"
              title="Edit">✏️ <span>Edit</span></button>
            <button type="button" class="about-btn-delete inline-flex items-center gap-1 text-red-600 bg-red-50 hover:bg-red-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition" data-id="${item.id}" title="Hapus">🗑️ <span>Hapus</span></button>
          </div>
        </div>
      `).join('');

      attachRowEvents();
    } catch (err) {
      loadingStateEl.classList.add('hidden');
      errorBannerEl.classList.remove('hidden');
      errorBannerEl.classList.add('flex');
      errorMsgEl.textContent = err.message;
      console.error('Gagal fetch keunggulan:', err);
    }
  }

  function resetForm() {
    document.getElementById('about-judul').value = '';
    document.getElementById('about-deskripsi').value = '';
    document.getElementById('about-urutan').value = '1';
    itemId.value = '';
    formTitle.textContent = '📝 Tambah Keunggulan';
    setStatus('', null);
    submitText.classList.remove('hidden');
    submitLoading.classList.add('hidden');
    submitLoading.classList.remove('inline-flex');
    btnSubmit.disabled = false;
    updateCharCount();
  }

  function setStatus(msg, type) {
    statusEl.textContent = msg;
    statusEl.className = 'font-medium text-sm rounded-lg transition';
    if (!msg) return;
    if (type === 'error') statusEl.className += ' bg-red-50 text-red-700 px-3 py-2.5';
    else if (type === 'success') statusEl.className += ' bg-emerald-100 text-emerald-800 px-3 py-2.5';
    else if (type === 'loading') statusEl.className += ' bg-blue-100 text-blue-800 px-3 py-2.5';
  }

  function updateCharCount() {
    const len = deskripsiEl.value.length;
    charCount.textContent = `${len}/200`;
    charCount.classList.toggle('text-red-600', len > 180);
    charCount.classList.toggle('text-slate-400', len <= 180);
  }
  deskripsiEl.addEventListener('input', updateCharCount);

  function openForm() {
    itemForm.classList.remove('hidden');
    requestAnimationFrame(() => {
      itemForm.classList.remove('max-h-0', 'opacity-0', '-translate-y-1.5');
      itemForm.classList.add('max-h-[900px]', 'opacity-100', 'translate-y-0');
    });
    itemForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function closeForm() {
    itemForm.classList.remove('max-h-[900px]', 'opacity-100', 'translate-y-0');
    itemForm.classList.add('max-h-0', 'opacity-0', '-translate-y-1.5');
    setTimeout(() => itemForm.classList.add('hidden'), 200);
  }

  btnTambah.addEventListener('click', () => {
    resetForm();
    openForm();
    document.getElementById('about-judul').focus();
  });

  btnBatal.addEventListener('click', () => {
    closeForm();
    resetForm();
  });

  function attachRowEvents() {
    itemListEl.querySelectorAll('.about-btn-edit').forEach((btn) => {
      btn.addEventListener('click', () => {
        itemId.value = btn.dataset.id;
        document.getElementById('about-judul').value = btn.dataset.judul;
        document.getElementById('about-deskripsi').value = btn.dataset.deskripsi;
        document.getElementById('about-urutan').value = btn.dataset.urutan;
        formTitle.textContent = '📝 Edit Keunggulan';
        openForm();
        document.getElementById('about-judul').focus();
        updateCharCount();
      });
    });

    itemListEl.querySelectorAll('.about-btn-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const container = btn.closest('[data-id]');
        if (!container) return;
        const judulEl = container.querySelector('strong');
        const judul = judulEl ? judulEl.textContent.trim() : 'data ini';
        
        if (!confirm(`Yakin ingin menghapus keunggulan "${judul}"?`)) return;

        const id = btn.dataset.id;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '⏳ <span>Menghapus...</span>';
        btn.disabled = true;

        try {
          const { error } = await supabase.from('keunggulan').delete().eq('id', id);
          if (error) throw error;
          await loadItems();
        } catch (err) {
          alert('Gagal menghapus: ' + err.message);
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    });
  }

  // --- Submit (tanpa gambar) ---
  itemForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const judul = document.getElementById('about-judul').value.trim();
    const deskripsi = document.getElementById('about-deskripsi').value.trim();
    const urutan = parseInt(document.getElementById('about-urutan').value, 10);

    if (!judul) {
      setStatus('Judul wajib diisi.', 'error');
      document.getElementById('about-judul').focus();
      return;
    }
    if (!deskripsi) {
      setStatus('Deskripsi wajib diisi.', 'error');
      document.getElementById('about-deskripsi').focus();
      return;
    }
    if (isNaN(urutan) || urutan < 1) {
      setStatus('Urutan harus angka positif.', 'error');
      document.getElementById('about-urutan').focus();
      return;
    }

    setStatus('Menyimpan...', 'loading');
    submitText.classList.add('hidden');
    submitLoading.classList.remove('hidden');
    submitLoading.classList.add('inline-flex');
    btnSubmit.disabled = true;

    const payload = { judul, deskripsi, urutan };

    try {
      let error;
      if (itemId.value) {
        ({ error } = await supabase.from('keunggulan').update(payload).eq('id', itemId.value));
      } else {
        ({ error } = await supabase.from('keunggulan').insert(payload));
      }
      if (error) throw error;

      setStatus('Tersimpan!', 'success');
      closeForm();
      resetForm();
      await loadItems();
    } catch (err) {
      setStatus('Gagal menyimpan: ' + err.message, 'error');
      submitText.classList.remove('hidden');
      submitLoading.classList.add('hidden');
      submitLoading.classList.remove('inline-flex');
      btnSubmit.disabled = false;
    }
  });

  loadItems();
</script>