---
// =============================================================
// components/admin/HeroForm.astro
// Panel ADMIN untuk kelola Hero (client-side, Tailwind)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col items-stretch gap-4 mb-7 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola Hero</h2>
      <p class="text-slate-500 text-sm m-0 leading-snug">Atur konten section hero (banner utama) yang tampil paling atas di halaman publik.</p>
    </div>
  </div>

  <!-- FORM -->
  <form id="heroForm" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">
          Eyebrow <span class="font-normal text-slate-400 text-xs">(opsional)</span>
        </label>
        <input type="text" id="hEyebrow" placeholder="Kompetisi Kompetensi Akademik 2026"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">
          Judul Utama <span class="text-red-600">*</span>
        </label>
        <input type="text" id="hJudul" placeholder="Raih Prestasi Terbaikmu" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <label class="font-semibold text-[0.87rem] text-slate-800">Subtitle / Deskripsi Singkat</label>
      <textarea id="hSubtitle" rows="3" placeholder="Ikuti kompetisi akademik tingkat kabupaten..."
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white resize-y min-h-[75px] focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"></textarea>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">Tanggal Pelaksanaan</label>
        <input type="date" id="hTanggal"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">Lokasi</label>
        <input type="text" id="hLokasi" placeholder="Gedung Serbaguna Kabupaten"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <!-- Upload Gambar -->
    <div class="flex flex-col gap-1.5">
      <label class="font-semibold text-[0.87rem] text-slate-800">Gambar Background</label>
      <input type="file" id="hGambarFile" accept="image/*"
        class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" />
      <small class="text-slate-400 text-[0.78rem]">Upload gambar baru untuk mengganti gambar saat ini. Kosongkan jika tidak ingin mengganti.</small>
      
      <!-- Preview gambar -->
      <div class="mt-2">
        <img id="hPreview" class="max-w-full max-h-48 rounded-lg object-cover border border-slate-200 hidden" alt="Pratinjau gambar hero" />
      </div>
      <input type="hidden" id="hGambarUrl" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">Label Tombol CTA</label>
        <input type="text" id="hTombolLabel" placeholder="Daftar Sekarang"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="font-semibold text-[0.87rem] text-slate-800">Link Tombol CTA</label>
        <input type="text" id="hTombolHref" placeholder="/regulasi#pendaftaran"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex items-center gap-4 flex-wrap pt-2">
      <button type="submit" id="hSubmitBtn"
        class="inline-flex items-center gap-2 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed">
        Simpan Perubahan
      </button>
      <span id="hStatus" class="font-medium text-sm min-h-[1.8rem]"></span>
    </div>
  </form>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  const BUCKET = 'hero';
  const heroForm = document.getElementById('heroForm');
  const hStatus = document.getElementById('hStatus');
  const hSubmitBtn = document.getElementById('hSubmitBtn');
  const hGambarFile = document.getElementById('hGambarFile');
  const hPreview = document.getElementById('hPreview');
  const hGambarUrl = document.getElementById('hGambarUrl');

  // --- Load data dari Supabase ---
  async function loadData() {
    try {
      const { data, error } = await supabase.from('hero_content').select('*').single();
      if (error && error.code !== 'PGRST116') throw error; // PGRST116 = no rows

      if (data) {
        document.getElementById('hEyebrow').value = data.eyebrow || '';
        document.getElementById('hJudul').value = data.judul || '';
        document.getElementById('hSubtitle').value = data.subtitle || '';
        document.getElementById('hTanggal').value = data.tanggal_pelaksanaan || '';
        document.getElementById('hLokasi').value = data.lokasi || '';
        document.getElementById('hTombolLabel').value = data.tombol_label || '';
        document.getElementById('hTombolHref').value = data.tombol_href || '';
        hGambarUrl.value = data.gambar_bg || '';

        if (data.gambar_bg) {
          hPreview.src = data.gambar_bg;
          hPreview.classList.remove('hidden');
        }
      }
    } catch (err) {
      console.error('Gagal memuat hero:', err);
      hStatus.textContent = '❌ Gagal memuat data hero.';
      hStatus.className = 'font-medium text-sm text-red-600';
    }
  }

  loadData();

  // --- Preview gambar ---
  hGambarFile.addEventListener('change', () => {
    const file = hGambarFile.files?.[0];
    if (file) {
      hPreview.src = URL.createObjectURL(file);
      hPreview.classList.remove('hidden');
    } else {
      // Kembalikan ke gambar sebelumnya jika ada
      if (hGambarUrl.value) {
        hPreview.src = hGambarUrl.value;
        hPreview.classList.remove('hidden');
      } else {
        hPreview.classList.add('hidden');
      }
    }
  });

  // --- Submit ---
  heroForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const judul = document.getElementById('hJudul').value.trim();
    if (!judul) {
      hStatus.textContent = '⚠️ Judul utama wajib diisi.';
      hStatus.className = 'font-medium text-sm text-amber-600';
      return;
    }

    hSubmitBtn.disabled = true;
    hStatus.textContent = '⏳ Menyimpan...';
    hStatus.className = 'font-medium text-sm text-blue-600';

    try {
      let gambarUrl = hGambarUrl.value;

      const file = hGambarFile.files?.[0];
      if (file) {
        hStatus.textContent = '⏳ Mengunggah gambar...';
        const ext = file.name.split('.').pop();
        const fileName = `${crypto.randomUUID()}.${ext}`;

        const { error: uploadError } = await supabase.storage
          .from(BUCKET)
          .upload(fileName, file);

        if (uploadError) {
          hStatus.textContent = '❌ Gagal upload gambar: ' + uploadError.message;
          hStatus.className = 'font-medium text-sm text-red-600';
          hSubmitBtn.disabled = false;
          return;
        }

        const { data: publicUrlData } = supabase.storage
          .from(BUCKET)
          .getPublicUrl(fileName);

        gambarUrl = publicUrlData.publicUrl;
      }

      const payload = {
        eyebrow: document.getElementById('hEyebrow').value.trim(),
        judul: judul,
        subtitle: document.getElementById('hSubtitle').value.trim(),
        tanggal_pelaksanaan: document.getElementById('hTanggal').value || null,
        lokasi: document.getElementById('hLokasi').value.trim(),
        gambar_bg: gambarUrl,
        tombol_label: document.getElementById('hTombolLabel').value.trim(),
        tombol_href: document.getElementById('hTombolHref').value.trim(),
      };

      const { data: existing } = await supabase.from('hero_content').select('id').single();

      let error;
      if (existing) {
        ({ error } = await supabase.from('hero_content').update(payload).eq('id', existing.id));
      } else {
        ({ error } = await supabase.from('hero_content').insert(payload));
      }

      if (error) {
        hStatus.textContent = '❌ Gagal menyimpan: ' + error.message;
        hStatus.className = 'font-medium text-sm text-red-600';
      } else {
        hStatus.textContent = '✅ Tersimpan! Halaman akan dimuat ulang...';
        hStatus.className = 'font-medium text-sm text-emerald-700';
        setTimeout(() => window.location.reload(), 1000);
      }
    } catch (err) {
      hStatus.textContent = '❌ Terjadi kesalahan tak terduga.';
      hStatus.className = 'font-medium text-sm text-red-600';
    } finally {
      hSubmitBtn.disabled = false;
    }
  });
</script>