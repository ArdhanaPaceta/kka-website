---
// =============================================================
// components/admin/FooterForm.astro
// Panel ADMIN untuk kelola Footer (client‑side, Tailwind)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-7">
    <div>
      <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola Footer</h2>
      <p class="text-slate-500 text-sm m-0 leading-snug">Atur informasi kontak dan sosial media di footer. Quick Links otomatis mengikuti menu Navbar.</p>
    </div>
  </div>

  <!-- FORM INFO FOOTER -->
  <form id="footerInfoForm" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label for="logo_url" class="font-semibold text-[0.87rem] text-slate-800">URL Logo</label>
        <input type="text" id="logo_url" name="logo_url" placeholder="https://example.com/logo.png"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="tagline" class="font-semibold text-[0.87rem] text-slate-800">Tagline</label>
        <input type="text" id="tagline" name="tagline" placeholder="Tagline website"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="alamat" class="font-semibold text-[0.87rem] text-slate-800">Alamat</label>
      <input type="text" id="alamat" name="alamat" placeholder="Jl. Contoh No. 123, Kota"
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label for="email" class="font-semibold text-[0.87rem] text-slate-800">Email</label>
        <input type="email" id="email" name="email" placeholder="info@example.com"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="telepon" class="font-semibold text-[0.87rem] text-slate-800">Telepon</label>
        <input type="text" id="telepon" name="telepon" placeholder="+62 812 3456 7890"
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex items-center gap-4 flex-wrap pt-2">
      <button type="submit" class="inline-flex items-center gap-2 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed">Simpan Info Footer</button>
      <span id="footerStatus" class="font-medium text-sm min-h-[1.8rem]"></span>
    </div>
  </form>

  <hr class="border-0 border-t-2 border-slate-200 my-5" />

  <!-- SOSIAL MEDIA -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
    <h3 class="text-[1.1rem] font-bold text-slate-900">Sosial Media</h3>
    <button type="button" id="btnTambahSosial" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap">
      <span class="text-lg leading-none">+</span> Tambah Sosial Media
    </button>
  </div>

  <!-- Error banner -->
  <div id="footerErrorBanner" class="hidden items-start gap-2.5 bg-red-50 border border-red-200 px-4 py-3.5 rounded-[10px] mb-6">
    <span class="text-lg leading-snug">⚠️</span>
    <div>
      <p class="m-0 text-red-700 text-sm leading-snug"><strong>Gagal memuat data:</strong> <span id="footerErrorMsg"></span></p>
      <p class="text-[0.82rem] text-red-800 mt-1">Pastikan tabel "footer_social_links" ada dan RLS mengizinkan SELECT.</p>
    </div>
  </div>

  <!-- Loading state (social list) -->
  <div id="socialLoadingState" class="text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-[1.8rem] mb-2">⏳</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Memuat data sosial media...</p>
  </div>

  <!-- List sosial media (diisi via JS) -->
  <div id="socialList" class="hidden flex-col gap-2.5 mb-6"></div>

  <!-- Empty state -->
  <div id="socialEmptyState" class="hidden text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <span class="text-2xl mb-2 block">🔗</span>
    <p class="font-semibold text-slate-700 m-0 mb-1">Belum ada sosial media.</p>
    <span class="text-sm text-slate-400">Klik tombol "Tambah Sosial Media" untuk mulai.</span>
  </div>

  <!-- Form Tambah/Edit Sosial Media (SEKARANG <form>) -->
  <form id="socialForm" class="hidden overflow-hidden max-h-0 opacity-0 -translate-y-1.5 transition-all duration-300 ease-in-out">
    <hr class="border-0 border-t-2 border-slate-200 my-2 mb-5" />
    <h3 id="socialFormTitle" class="text-[1.1rem] font-bold text-slate-900 mb-5">Tambah Sosial Media</h3>
    <input type="hidden" id="socialId" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="socialLabel" class="font-semibold text-[0.87rem] text-slate-800">Nama Platform</label>
        <input type="text" id="socialLabel" placeholder="Instagram" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="socialUrutan" class="font-semibold text-[0.87rem] text-slate-800">Urutan</label>
        <input type="number" id="socialUrutan" value="1" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <label for="socialIcon" class="font-semibold text-[0.87rem] text-slate-800">Icon (emoji)</label>
      <input type="text" id="socialIcon" placeholder="📷"
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      <small class="text-slate-400 text-[0.78rem] mt-0.5">Contoh: 📷, 🐦, 📘, 💼 (opsional)</small>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <label for="socialHref" class="font-semibold text-[0.87rem] text-slate-800">Link</label>
      <input type="text" id="socialHref" placeholder="https://instagram.com/..." required
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
    </div>

    <p id="socialStatus" class="font-medium text-sm rounded-lg transition mb-4"></p>

    <div class="flex gap-3 flex-wrap">
      <button type="button" id="btnBatalSosial" class="bg-transparent border border-slate-300 text-slate-600 px-5 py-2.5 rounded-xl font-medium hover:bg-slate-100 hover:border-slate-400 transition">Batal</button>
      <button type="submit" class="inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">Simpan</button>
    </div>
  </form>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  // --- DOM Elements ---
  const footerInfoForm = document.getElementById('footerInfoForm');
  const footerStatus = document.getElementById('footerStatus');
  const socialLoadingState = document.getElementById('socialLoadingState');
  const socialListEl = document.getElementById('socialList');
  const socialEmptyState = document.getElementById('socialEmptyState');
  const socialForm = document.getElementById('socialForm');
  const socialFormTitle = document.getElementById('socialFormTitle');
  const socialId = document.getElementById('socialId');
  const socialStatus = document.getElementById('socialStatus');
  const errorBanner = document.getElementById('footerErrorBanner');
  const errorMsg = document.getElementById('footerErrorMsg');
  const btnTambahSosial = document.getElementById('btnTambahSosial');
  const btnBatalSosial = document.getElementById('btnBatalSosial');

  // --- State Management ---
  function showError(msg) {
    errorMsg.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.classList.add('flex');
  }

  function hideError() {
    errorBanner.classList.add('hidden');
    errorBanner.classList.remove('flex');
  }

  function showSocialLoading() {
    socialLoadingState.classList.remove('hidden');
    socialListEl.classList.add('hidden');
    socialListEl.classList.remove('flex');
    socialEmptyState.classList.add('hidden');
  }

  function showSocialList() {
    socialLoadingState.classList.add('hidden');
    socialListEl.classList.remove('hidden');
    socialListEl.classList.add('flex');
    socialEmptyState.classList.add('hidden');
  }

  function showSocialEmpty() {
    socialLoadingState.classList.add('hidden');
    socialListEl.classList.add('hidden');
    socialListEl.classList.remove('flex');
    socialEmptyState.classList.remove('hidden');
  }

  function resetSocialForm() {
    socialForm.reset();
    socialId.value = '';
    socialFormTitle.textContent = 'Tambah Sosial Media';
    document.getElementById('socialUrutan').value = 1;
    socialStatus.textContent = '';
    socialStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
  }

  function setSocialStatus(msg, type) {
    socialStatus.textContent = msg;
    socialStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
    if (type === 'error') socialStatus.classList.add('text-red-700', 'bg-red-50', 'px-3', 'py-2.5');
    else if (type === 'success') socialStatus.classList.add('text-emerald-800', 'bg-emerald-100', 'px-3', 'py-2.5');
    else if (type === 'loading') socialStatus.classList.add('text-blue-800', 'bg-blue-100', 'px-3', 'py-2.5');
  }

  function setFooterStatus(msg, type) {
    footerStatus.textContent = msg;
    footerStatus.className = 'font-medium text-sm min-h-[1.8rem]';
    if (type === 'error') footerStatus.classList.add('text-red-600');
    else if (type === 'success') footerStatus.classList.add('text-emerald-700');
    else if (type === 'loading') footerStatus.classList.add('text-blue-600');
  }

  // --- Load Footer Info ---
  async function loadFooterInfo() {
    try {
      const { data, error } = await supabase.from('footer_content').select('*').single();
      if (error && error.code !== 'PGRST116') throw error;
      if (data) {
        document.getElementById('logo_url').value = data.logo_url || '';
        document.getElementById('tagline').value = data.tagline || '';
        document.getElementById('alamat').value = data.alamat || '';
        document.getElementById('email').value = data.email || '';
        document.getElementById('telepon').value = data.telepon || '';
      }
    } catch (err) {
      console.error('Gagal memuat info footer:', err);
    }
  }

  // --- Simpan Info Footer ---
  footerInfoForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    setFooterStatus('⏳ Menyimpan...', 'loading');
    const payload = {
      logo_url: document.getElementById('logo_url').value.trim(),
      tagline: document.getElementById('tagline').value.trim(),
      alamat: document.getElementById('alamat').value.trim(),
      email: document.getElementById('email').value.trim(),
      telepon: document.getElementById('telepon').value.trim(),
    };

    try {
      const { data: existing } = await supabase.from('footer_content').select('id').single();
      let error;
      if (existing) {
        ({ error } = await supabase.from('footer_content').update(payload).eq('id', existing.id));
      } else {
        ({ error } = await supabase.from('footer_content').insert(payload));
      }
      if (error) throw error;
      setFooterStatus('✅ Tersimpan!', 'success');
      setTimeout(() => setFooterStatus('', ''), 2000);
    } catch (err) {
      setFooterStatus('❌ Gagal: ' + err.message, 'error');
    }
  });

  // --- CRUD Sosial Media ---
  async function loadSocialLinks() {
    showSocialLoading();
    hideError();
    try {
      const { data, error } = await supabase
        .from('footer_social_links')
        .select('*')
        .order('urutan', { ascending: true });
      if (error) throw error;
      if (!data || data.length === 0) {
        showSocialEmpty();
        return;
      }
      renderSocialList(data);
      showSocialList();
    } catch (err) {
      console.error('Gagal fetch social links:', err);
      showError(err.message);
    }
  }

  function renderSocialList(items) {
    socialListEl.innerHTML = items.map((item) => `
      <div class="flex items-center flex-wrap sm:flex-nowrap gap-3.5 px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-100 hover:bg-slate-100/60 hover:border-slate-200 hover:shadow-[0_2px_8px_rgba(15,23,42,0.04)] transition" data-id="${item.id}">
        <div class="flex-1 min-w-[150px]">
          <div class="flex items-center flex-wrap gap-2 mb-1">
            <span class="text-lg">${item.icon || '🌐'}</span>
            <strong class="text-[0.98rem] text-slate-900">${item.label}</strong>
            <span class="bg-indigo-50 text-blue-600 text-[0.7rem] font-bold px-2.5 py-0.5 rounded-full tracking-wide">Urutan #${item.urutan}</span>
          </div>
          <a href="${item.href}" target="_blank" rel="noopener" class="text-blue-600 text-[0.85rem] break-all hover:underline">${item.href}</a>
        </div>
        <div class="flex gap-1.5 flex-shrink-0 w-full justify-end sm:w-auto">
          <button type="button" class="btn-edit-social text-blue-600 bg-blue-50 hover:bg-blue-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1"
            data-id="${item.id}" data-label="${item.label}" data-href="${item.href}" data-icon="${item.icon || ''}" data-urutan="${item.urutan}">
            ✏️ <span>Edit</span>
          </button>
          <button type="button" class="btn-delete-social text-red-600 bg-red-50 hover:bg-red-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1" data-id="${item.id}">
            🗑️ <span>Hapus</span>
          </button>
        </div>
      </div>
    `).join('');

    attachSocialRowEvents();
  }

  function attachSocialRowEvents() {
    socialListEl.querySelectorAll('.btn-edit-social').forEach((btn) => {
      btn.addEventListener('click', () => {
        socialId.value = btn.dataset.id;
        document.getElementById('socialLabel').value = btn.dataset.label;
        document.getElementById('socialHref').value = btn.dataset.href;
        document.getElementById('socialIcon').value = btn.dataset.icon || '';
        document.getElementById('socialUrutan').value = btn.dataset.urutan;
        socialFormTitle.textContent = 'Edit Sosial Media';
        openSocialForm();
        document.getElementById('socialLabel').focus();
        setSocialStatus('', '');
      });
    });

    socialListEl.querySelectorAll('.btn-delete-social').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Yakin ingin menghapus sosial media ini?')) return;
        const id = btn.dataset.id;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '⏳ <span>Menghapus...</span>';
        btn.disabled = true;
        try {
          const { error } = await supabase.from('footer_social_links').delete().eq('id', id);
          if (error) throw error;
          await loadSocialLinks();
        } catch (err) {
          alert('Gagal menghapus: ' + err.message);
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    });
  }

  function openSocialForm() {
    socialForm.classList.remove('hidden');
    requestAnimationFrame(() => {
      socialForm.classList.remove('max-h-0', 'opacity-0', '-translate-y-1.5');
      socialForm.classList.add('max-h-[900px]', 'opacity-100', 'translate-y-0');
    });
    socialForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function closeSocialForm() {
    socialForm.classList.remove('max-h-[900px]', 'opacity-100', 'translate-y-0');
    socialForm.classList.add('max-h-0', 'opacity-0', '-translate-y-1.5');
    setTimeout(() => {
      socialForm.classList.add('hidden');
      resetSocialForm();
    }, 200);
  }

  btnTambahSosial.addEventListener('click', () => {
    resetSocialForm();
    openSocialForm();
    document.getElementById('socialLabel').focus();
  });

  btnBatalSosial.addEventListener('click', closeSocialForm);

  // SEKARANG socialForm adalah <form>, event submit akan bekerja
  socialForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const label = document.getElementById('socialLabel').value.trim();
    const href = document.getElementById('socialHref').value.trim();
    const icon = document.getElementById('socialIcon').value.trim();
    const urutan = parseInt(document.getElementById('socialUrutan').value, 10);

    if (!label || !href) {
      setSocialStatus('⚠️ Nama platform dan link wajib diisi.', 'error');
      return;
    }

    setSocialStatus('⏳ Menyimpan...', 'loading');
    const payload = { label, href, icon: icon || null, urutan };

    try {
      let error;
      if (socialId.value) {
        ({ error } = await supabase.from('footer_social_links').update(payload).eq('id', socialId.value));
      } else {
        ({ error } = await supabase.from('footer_social_links').insert(payload));
      }
      if (error) throw error;

      setSocialStatus('✅ Tersimpan!', 'success');
      setTimeout(async () => {
        closeSocialForm();
        resetSocialForm();
        await loadSocialLinks();
      }, 800);
    } catch (err) {
      setSocialStatus('❌ Gagal: ' + err.message, 'error');
    }
  });

  // --- Init ---
  loadFooterInfo();
  loadSocialLinks();
</script>