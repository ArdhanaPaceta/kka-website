---
// =============================================================
// components/admin/FAQForm.astro
// Panel ADMIN untuk kelola FAQ (client‑side, Tailwind)
// =============================================================
---

<div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-7 border border-slate-100 shadow-[0_4px_20px_rgba(15,23,42,0.05)]">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-7">
    <div>
      <h2 class="text-[1.35rem] font-bold text-slate-900 mt-1 mb-1">Kelola FAQ</h2>
      <p class="text-slate-500 text-sm m-0 leading-snug">Atur daftar pertanyaan yang sering diajukan.</p>
    </div>
    <button type="button" id="btnTambahFaq" class="w-full bg- sm:w-auto inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-black  font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap">
      <span class="text-lg leading-none">+</span> Tambah FAQ
    </button>
  </div>

  <!-- Error banner -->
  <div id="faqErrorBanner" class="hidden items-start gap-2.5 bg-red-50 border border-red-200 px-4 py-3.5 rounded-[10px] mb-6">
    <span class="text-lg leading-snug">⚠️</span>
    <div>
      <p class="m-0 text-red-700 text-sm leading-snug"><strong>Gagal memuat data:</strong> <span id="faqErrorMsg"></span></p>
      <p class="text-[0.82rem] text-red-800 mt-1">Pastikan tabel "faqs" ada dan RLS mengizinkan SELECT.</p>
    </div>
  </div>

  <!-- Loading state -->
  <div id="faqLoadingState" class="text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <div class="text-[1.8rem] mb-2">⏳</div>
    <p class="font-semibold text-slate-700 m-0 mb-1">Memuat data FAQ...</p>
  </div>

  <!-- List FAQ (diisi via JS) -->
  <div id="faqList" class="hidden flex-col gap-2.5 mb-6"></div>

  <!-- Empty state -->
  <div id="faqEmptyState" class="hidden text-center py-11 px-4 bg-slate-50 rounded-2xl border-[1.5px] border-dashed border-slate-200">
    <span class="text-2xl mb-2 block">❓</span>
    <p class="font-semibold text-slate-700 m-0 mb-1">Belum ada FAQ.</p>
    <span class="text-sm text-slate-400">Klik tombol "Tambah FAQ" untuk mulai.</span>
  </div>

  <!-- Form Tambah/Edit FAQ -->
  <form id="faqForm" class="hidden overflow-hidden max-h-0 opacity-0 -translate-y-1.5 transition-all duration-300 ease-in-out">
    <hr class="border-0 border-t-2 border-slate-200 my-2 mb-5" />
    <h3 id="faqFormTitle" class="text-[1.1rem] font-bold text-slate-900 mb-5">Tambah FAQ</h3>
    <input type="hidden" id="faqId" />

    <div class="grid grid-cols-1 sm:grid-cols-[2fr_1fr] gap-4">
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="faqPertanyaan" class="font-semibold text-[0.87rem] text-slate-800">Pertanyaan</label>
        <input type="text" id="faqPertanyaan" placeholder="Tulis pertanyaan di sini..." required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
      <div class="flex flex-col gap-1.5 mb-4">
        <label for="faqUrutan" class="font-semibold text-[0.87rem] text-slate-800">Urutan Tampil</label>
        <input type="number" id="faqUrutan" value="1" required
          class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition" />
      </div>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <label for="faqJawaban" class="font-semibold text-[0.87rem] text-slate-800">Jawaban</label>
      <textarea id="faqJawaban" rows="4" placeholder="Tulis jawaban di sini..." required
        class="w-full px-3.5 py-2.5 border-[1.5px] border-slate-200 rounded-xl text-[0.93rem] bg-white resize-y min-h-[100px] focus:outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-600/10 transition"></textarea>
    </div>

    <p id="faqStatus" class="font-medium text-sm rounded-lg transition mb-4"></p>

    <div class="flex gap-3 flex-wrap">
      <button type="button" id="btnBatalFaq" class="bg-transparent border border-slate-300 text-slate-600 px-5 py-2.5 rounded-xl font-medium hover:bg-slate-100 hover:border-slate-400 transition">Batal</button>
      <button type="submit" class="inline-flex items-center justify-center gap-1.5 bg-gradient-to-br from-blue-600 to-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-xl shadow-[0_3px_10px_rgba(37,99,235,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(37,99,235,0.32)] active:translate-y-0 active:scale-95 transition disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">Simpan Data</button>
    </div>
  </form>
</div>

<script type="module">
  import { supabase } from '../../lib/supabase';

  // --- DOM Elements ---
  const btnTambahFaq = document.getElementById('btnTambahFaq');
  const faqForm = document.getElementById('faqForm');
  const btnBatalFaq = document.getElementById('btnBatalFaq');
  const faqFormTitle = document.getElementById('faqFormTitle');
  const faqId = document.getElementById('faqId');
  const faqStatus = document.getElementById('faqStatus');
  const faqListEl = document.getElementById('faqList');
  const faqEmptyState = document.getElementById('faqEmptyState');
  const faqLoadingState = document.getElementById('faqLoadingState');
  const errorBanner = document.getElementById('faqErrorBanner');
  const errorMsg = document.getElementById('faqErrorMsg');

  // --- State Management ---
  function showError(msg) {
    errorMsg.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.classList.add('flex');
  }

  function hideError() {
    errorBanner.classList.add('hidden');
    errorBanner.classList.remove('flex');
  }

  function showLoading() {
    faqLoadingState.classList.remove('hidden');
    faqListEl.classList.add('hidden');
    faqListEl.classList.remove('flex');
    faqEmptyState.classList.add('hidden');
  }

  function showList() {
    faqLoadingState.classList.add('hidden');
    faqListEl.classList.remove('hidden');
    faqListEl.classList.add('flex');
    faqEmptyState.classList.add('hidden');
  }

  function showEmpty() {
    faqLoadingState.classList.add('hidden');
    faqListEl.classList.add('hidden');
    faqListEl.classList.remove('flex');
    faqEmptyState.classList.remove('hidden');
  }

  function resetForm() {
    faqForm.reset();
    faqId.value = '';
    faqFormTitle.textContent = 'Tambah FAQ';
    document.getElementById('faqUrutan').value = 1;
    faqStatus.textContent = '';
    faqStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
  }

  function setStatus(msg, type) {
    faqStatus.textContent = msg;
    faqStatus.className = 'font-medium text-sm rounded-lg transition mb-4';
    if (type === 'error') faqStatus.classList.add('text-red-700', 'bg-red-50', 'px-3', 'py-2.5');
    else if (type === 'success') faqStatus.classList.add('text-emerald-800', 'bg-emerald-100', 'px-3', 'py-2.5');
    else if (type === 'loading') faqStatus.classList.add('text-blue-800', 'bg-blue-100', 'px-3', 'py-2.5');
  }

  // --- Load FAQ ---
  async function loadFaqs() {
    showLoading();
    hideError();
    try {
      const { data, error } = await supabase
        .from('faqs')
        .select('*')
        .order('urutan', { ascending: true });

      if (error) throw error;

      if (!data || data.length === 0) {
        showEmpty();
        return;
      }

      renderList(data);
      showList();
    } catch (err) {
      console.error('Gagal fetch FAQ:', err);
      showError(err.message);
    }
  }

  function renderList(items) {
    faqListEl.innerHTML = items.map((item) => `
      <div class="flex items-start flex-wrap sm:flex-nowrap gap-3.5 px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-100 hover:bg-slate-100/60 hover:border-slate-200 hover:shadow-[0_2px_8px_rgba(15,23,42,0.04)] transition" data-id="${item.id}">
        <div class="flex-1 min-w-[150px]">
          <div class="flex items-center flex-wrap gap-2 mb-1">
            <strong class="text-[0.98rem] text-slate-900">${item.pertanyaan}</strong>
            <span class="bg-indigo-50 text-blue-600 text-[0.7rem] font-bold px-2.5 py-0.5 rounded-full tracking-wide">Urutan #${item.urutan}</span>
          </div>
          <p class="text-slate-500 text-[0.87rem] mt-0.5 leading-snug line-clamp-3">${item.jawaban}</p>
        </div>
        <div class="flex gap-1.5 flex-shrink-0 w-full justify-end sm:w-auto">
          <button type="button" class="btn-edit-faq text-blue-600 bg-blue-50 hover:bg-blue-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1"
            data-id="${item.id}" data-pertanyaan="${item.pertanyaan.replace(/"/g, '&quot;')}" data-jawaban="${item.jawaban.replace(/"/g, '&quot;')}" data-urutan="${item.urutan}">
            ✏️ <span>Edit</span>
          </button>
          <button type="button" class="btn-delete-faq text-red-600 bg-red-50 hover:bg-red-100 px-3 py-2 rounded-lg text-[0.8rem] font-medium transition inline-flex items-center gap-1" data-id="${item.id}">
            🗑️ <span>Hapus</span>
          </button>
        </div>
      </div>
    `).join('');

    attachRowEvents();
  }

  function attachRowEvents() {
    // Edit
    faqListEl.querySelectorAll('.btn-edit-faq').forEach((btn) => {
      btn.addEventListener('click', () => {
        faqId.value = btn.dataset.id;
        document.getElementById('faqPertanyaan').value = btn.dataset.pertanyaan;
        document.getElementById('faqJawaban').value = btn.dataset.jawaban;
        document.getElementById('faqUrutan').value = btn.dataset.urutan;
        faqFormTitle.textContent = 'Edit FAQ';
        openForm();
        document.getElementById('faqPertanyaan').focus();
        setStatus('', '');
      });
    });

    // Delete
    faqListEl.querySelectorAll('.btn-delete-faq').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Yakin ingin menghapus FAQ ini?')) return;
        const id = btn.dataset.id;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '⏳ <span>Menghapus...</span>';
        btn.disabled = true;

        try {
          const { error } = await supabase.from('faqs').delete().eq('id', id);
          if (error) throw error;
          await loadFaqs();
        } catch (err) {
          alert('Gagal menghapus: ' + err.message);
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    });
  }

  // --- Form Toggle ---
  function openForm() {
    faqForm.classList.remove('hidden');
    requestAnimationFrame(() => {
      faqForm.classList.remove('max-h-0', 'opacity-0', '-translate-y-1.5');
      faqForm.classList.add('max-h-[900px]', 'opacity-100', 'translate-y-0');
    });
    faqForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function closeForm() {
    faqForm.classList.remove('max-h-[900px]', 'opacity-100', 'translate-y-0');
    faqForm.classList.add('max-h-0', 'opacity-0', '-translate-y-1.5');
    setTimeout(() => {
      faqForm.classList.add('hidden');
      resetForm();
    }, 200);
  }

  btnTambahFaq.addEventListener('click', () => {
    resetForm();
    openForm();
    document.getElementById('faqPertanyaan').focus();
  });

  btnBatalFaq.addEventListener('click', closeForm);

  // --- Submit ---
  faqForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pertanyaan = document.getElementById('faqPertanyaan').value.trim();
    const jawaban = document.getElementById('faqJawaban').value.trim();
    const urutan = parseInt(document.getElementById('faqUrutan').value, 10);

    if (!pertanyaan || !jawaban) {
      setStatus('⚠️ Pertanyaan dan jawaban wajib diisi.', 'error');
      return;
    }

    setStatus('⏳ Menyimpan...', 'loading');
    const payload = { pertanyaan, jawaban, urutan };

    try {
      let error;
      if (faqId.value) {
        ({ error } = await supabase.from('faqs').update(payload).eq('id', faqId.value));
      } else {
        ({ error } = await supabase.from('faqs').insert(payload));
      }
      if (error) throw error;

      setStatus('✅ Tersimpan!', 'success');
      setTimeout(async () => {
        closeForm();
        resetForm();
        await loadFaqs();
      }, 800);
    } catch (err) {
      setStatus('❌ Gagal menyimpan: ' + err.message, 'error');
    }
  });

  // --- Init ---
  loadFaqs();
</script>