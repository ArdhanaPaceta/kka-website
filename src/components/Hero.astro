---
import { supabase } from '../lib/supabase';
const { data: hero } = await supabase
  .from('hero_content')
  .select('*')
  .single();

const eventDate = hero?.tanggal_pelaksanaan
  ? `${hero.tanggal_pelaksanaan}T08:00:00`
  : '2026-10-17T08:00:00';

const formattedDate = hero?.tanggal_pelaksanaan
  ? new Date(hero.tanggal_pelaksanaan).toLocaleDateString('id-ID', {
      day: 'numeric', month: 'long', year: 'numeric'
    })
  : '17 Oktober 2026';
---

<section class="hero" id="beranda">
  <div class="hero__bg">
    <img src={hero?.gambar_bg || '/images/hero.jpg'} alt="Suasana Kompetisi Kompetensi Akademik" />
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <span class="hero__eyebrow reveal">{hero?.eyebrow}</span>

    <h1 class="hero__title reveal reveal-delay-1">
      {hero?.judul}
    </h1>

    <p class="hero__subtitle reveal reveal-delay-2">
      {hero?.subtitle}
    </p>

    <div class="hero__meta reveal reveal-delay-2">
      <div class="hero__meta-item">
        <span class="hero__meta-label">Tanggal Pelaksanaan</span>
        <span class="hero__meta-value">{formattedDate}</span>
      </div>
      <div class="hero__meta-divider"></div>
      <div class="hero__meta-item">
        <span class="hero__meta-label">Lokasi</span>
        <span class="hero__meta-value">{hero?.lokasi}</span>
      </div>
    </div>

    <div class="hero__countdown reveal reveal-delay-3" id="countdown" data-target={eventDate}>
      <div class="countdown__box">
        <span class="countdown__number" id="cd-days">00</span>
        <span class="countdown__label">Hari</span>
      </div>
      <div class="countdown__box">
        <span class="countdown__number" id="cd-hours">00</span>
        <span class="countdown__label">Jam</span>
      </div>
      <div class="countdown__box">
        <span class="countdown__number" id="cd-minutes">00</span>
        <span class="countdown__label">Menit</span>
      </div>
      <div class="countdown__box">
        <span class="countdown__number" id="cd-seconds">00</span>
        <span class="countdown__label">Detik</span>
      </div>
    </div>

    <div class="hero__buttons reveal reveal-delay-4">
      <a href={hero?.tombol_href || '/regulasi#pendaftaran'} class="btn btn-primary">{hero?.tombol_label || 'Daftar Sekarang'}</a>
      <a href="#tentang" class="btn btn-outline">Pelajari Lebih Lanjut</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(15, 23, 42, 0.75) 0%,
      rgba(15, 23, 42, 0.55) 45%,
      rgba(15, 23, 42, 0.92) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: 120px;
    max-width: 780px;
  }

  .hero__eyebrow {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.8rem;
    margin-bottom: 20px;
  }

  .hero__title {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .hero__subtitle {
    color: rgba(248, 250, 252, 0.85);
    font-size: 1.05rem;
    max-width: 600px;
    margin-bottom: 32px;
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero__meta-label {
    font-size: 0.75rem;
    color: rgba(248, 250, 252, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero__meta-value {
    font-weight: 600;
    color: var(--color-white);
  }

  .hero__meta-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.25);
  }

  .hero__countdown {
    display: flex;
    gap: 14px;
    margin-bottom: 40px;
  }

  .countdown__box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 76px;
    height: 76px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-sm);
    backdrop-filter: blur(6px);
  }

  .countdown__number {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-white);
    font-variant-numeric: tabular-nums;
  }

  .countdown__label {
    font-size: 0.7rem;
    color: rgba(248, 250, 252, 0.65);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
  }

  .hero__buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 20px;
    z-index: 1;
  }

  .hero__scroll-indicator span {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 2px;
    animation: scroll-dot 1.6s infinite;
  }

  @keyframes scroll-dot {
    0% { opacity: 1; top: 8px; }
    100% { opacity: 0; top: 22px; }
  }

  @media (max-width: 600px) {
    .countdown__box {
      width: 62px;
      height: 62px;
    }
    .hero__meta {
      gap: 16px;
    }
  }
</style>

<script>
  // ===========================================================
  // Countdown Timer — Vanilla JavaScript
  // ===========================================================
  const countdownEl = document.getElementById('countdown');
  const target = countdownEl ? new Date(countdownEl.dataset.target || '').getTime() : 0;

  const daysEl = document.getElementById('cd-days');
  const hoursEl = document.getElementById('cd-hours');
  const minutesEl = document.getElementById('cd-minutes');
  const secondsEl = document.getElementById('cd-seconds');

  function pad(num: number) {
    return String(num).padStart(2, '0');
  }

  function updateCountdown() {
    const now = new Date().getTime();
    const distance = target - now;

    if (distance <= 0) {
      if (daysEl) daysEl.textContent = '00';
      if (hoursEl) hoursEl.textContent = '00';
      if (minutesEl) minutesEl.textContent = '00';
      if (secondsEl) secondsEl.textContent = '00';
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    if (daysEl) daysEl.textContent = pad(days);
    if (hoursEl) hoursEl.textContent = pad(hours);
    if (minutesEl) minutesEl.textContent = pad(minutes);
    if (secondsEl) secondsEl.textContent = pad(seconds);
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
